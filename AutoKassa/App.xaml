<Application x:Class="AutoKassa.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Стили будут добавлены позже -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Основные цвета приложения -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="#2196F3"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="#F44336"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#FF9800"/>

            <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#F5F5F5"/>
            <SolidColorBrush x:Key="ForegroundBrush" Color="#212121"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#757575"/>

            <!-- Размеры -->
            <System:Double x:Key="FontSizeSmall" xmlns:System="clr-namespace:System;assembly=mscorlib">12</System:Double>
            <System:Double x:Key="FontSizeNormal" xmlns:System="clr-namespace:System;assembly=mscorlib">14</System:Double>
            <System:Double x:Key="FontSizeLarge" xmlns:System="clr-namespace:System;assembly=mscorlib">16</System:Double>
            <System:Double x:Key="FontSizeH1" xmlns:System="clr-namespace:System;assembly=mscorlib">24</System:Double>
            <System:Double x:Key="FontSizeH2" xmlns:System="clr-namespace:System;assembly=mscorlib">20</System:Double>
            <System:Double x:Key="FontSizeH3" xmlns:System="clr-namespace:System;assembly=mscorlib">16</System:Double>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:DecimalToStringConverter x:Key="DecimalToStringConverter"/>
            <converters:OperationTypeToColorConverter x:Key="OperationTypeToColorConverter"/>
            <converters:OperationTypeToTextConverter x:Key="OperationTypeToTextConverter"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>