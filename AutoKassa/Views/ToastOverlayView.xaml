<UserControl x:Class="AutoKassa.Views.ToastOverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Center"
             VerticalAlignment="Bottom">

    <Border x:Name="ToastBorder"
            Background="#fef2f2"
            BorderBrush="#fecaca"
            BorderThickness="1"
            CornerRadius="12"
            MinWidth="260"
            MaxWidth="480"
            ClipToBounds="True"
            Visibility="Collapsed">

        <StackPanel>
            <!-- Основной контент -->
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Иконка корзины -->
                <Viewbox Grid.Column="0" Width="15" Height="15"
                         VerticalAlignment="Center" Margin="0,0,10,0">
                    <Canvas Width="24" Height="24">
                        <Path Stroke="#ef4444" StrokeThickness="2.2"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Data="M3,6 L5,6 L21,6 M19,6 V20 a2,2 0 0,1 -2,2 H7 a2,2 0 0,1 -2,-2 V6 M8,6 V4 a2,2 0 0,1 2,-2 h4 a2,2 0 0,1 2,2 V6"/>
                    </Canvas>
                </Viewbox>

                <!-- Текст сообщения -->
                <TextBlock Grid.Column="1"
                           x:Name="MessageText"
                           Foreground="#374151"
                           FontSize="13"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>

                <!-- Кнопка «Отменить» -->
                <Button Grid.Column="2"
                        x:Name="UndoButton"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="14,0,0,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Click="UndoButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="txt"
                                       Text="↩ Отменить"
                                       Foreground="#ef4444"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="txt" Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Полоса обратного отсчёта: ScaleTransform от правого края -->
            <Border Height="3" Background="#fecaca">
                <Border x:Name="ProgressFill"
                        Background="#ef4444"
                        Height="3"
                        HorizontalAlignment="Stretch"
                        RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ProgressScale" ScaleX="1"/>
                    </Border.RenderTransform>
                </Border>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
