<UserControl x:Class="AutoKassa.Views.TransactionEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             Background="White">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>

        <!-- Style for category chip ListBoxItem -->
        <Style x:Key="CategoryChipItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,7,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="chip"
                                Background="#F0F2F5"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="chip" Property="Background" Value="#1A1D23"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="chip" Property="Background" Value="#E2E5EA"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Calc button style -->
        <Style x:Key="CalcBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#F0F2F5"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E2E5EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#D0D5DD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalcOpBtnStyle" TargetType="Button" BasedOn="{StaticResource CalcBtnStyle}">
            <Setter Property="Background" Value="#E8EAED"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CalcEqBtnStyle" TargetType="Button" BasedOn="{StaticResource CalcBtnStyle}">
            <Setter Property="Background" Value="#22c55e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.InputBindings>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">

            <!-- ===== TITLE + close button ===== -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold"
                           Foreground="#1A1D23" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Command="{Binding CancelCommand}" Cursor="Hand"
                        Width="28" Height="28" ToolTip="Закрыть (Esc)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                <TextBlock Text="✕" FontSize="14" Foreground="#98A2B3"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="MouseOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bg"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#F0F2F5"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ===== TYPE TOGGLE: Расход / Доход ===== -->
            <Border Background="#F0F2F5" CornerRadius="11" Padding="3" Margin="0,0,0,18">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Расход" Command="{Binding SelectExpenseTypeCommand}"
                            Cursor="Hand" Width="190" Height="36">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#667085"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpense}" Value="True">
                                        <Setter Property="Background" Value="#ef4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Доход" Command="{Binding SelectIncomeTypeCommand}"
                            Cursor="Hand" Width="190" Height="36">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#667085"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                        <Setter Property="Background" Value="#22c55e"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ===== AMOUNT BLOCK ===== -->
            <Border Background="#F8F9FB" CornerRadius="14" Padding="18" Margin="0,0,0,18">
                <StackPanel>
                    <!-- Amount input row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AmountTextBox"
                                 Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="32" FontWeight="SemiBold" FontFamily="Consolas"
                                 TextAlignment="Center"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Center"
                                 Foreground="#1A1D23"
                                 TabIndex="0"
                                 PreviewTextInput="AmountTextBox_PreviewTextInput"
                                 TextChanged="AmountTextBox_TextChanged">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SaveCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <!-- Calculator toggle button -->
                        <Button Grid.Column="1" Command="{Binding ToggleCalcCommand}"
                                Cursor="Hand" Width="34" Height="34" ToolTip="Калькулятор">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="8">
                                        <TextBlock FontSize="18" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="≡"/>
                                                    <Setter Property="Foreground" Value="#98A2B3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCalcOpen}" Value="True">
                                                            <Setter Property="Foreground" Value="#22c55e"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal"/>
                                                <VisualState x:Name="MouseOver">
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bg"
                                                            Storyboard.TargetProperty="Background">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="#F0F2F5"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <TextBlock Text="Сумма в рублях" FontSize="11" Foreground="#98A2B3"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding AmountError}"
                               FontSize="12" Foreground="#ef4444" HorizontalAlignment="Center"
                               Margin="0,6,0,0"
                               Visibility="{Binding AmountError, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- ===== CALCULATOR ===== -->
                    <Grid Margin="0,10,0,0"
                          Visibility="{Binding IsCalcOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="38"/>
                            <RowDefinition Height="38"/>
                            <RowDefinition Height="38"/>
                            <RowDefinition Height="38"/>
                            <RowDefinition Height="38"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Display -->
                        <Border Grid.Row="0" Grid.ColumnSpan="4"
                                Background="#1A1D23" CornerRadius="8" Padding="10,6" Margin="2,0,2,6">
                            <TextBlock Text="{Binding CalcDisplay}" FontFamily="Consolas" FontSize="13"
                                       Foreground="White" TextAlignment="Right" MinHeight="18"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>

                        <!-- Row 1: C ⌫ ÷ × -->
                        <Button Grid.Row="1" Grid.Column="0" Content="C" Command="{Binding CalcClearCommand}"
                                Style="{StaticResource CalcOpBtnStyle}" Foreground="#ef4444"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="⌫" Command="{Binding CalcBackspaceCommand}"
                                Style="{StaticResource CalcOpBtnStyle}"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="÷" Command="{Binding CalcOpCommand}"
                                CommandParameter="÷" Style="{StaticResource CalcOpBtnStyle}"/>
                        <Button Grid.Row="1" Grid.Column="3" Content="×" Command="{Binding CalcOpCommand}"
                                CommandParameter="×" Style="{StaticResource CalcOpBtnStyle}"/>

                        <!-- Row 2: 7 8 9 − -->
                        <Button Grid.Row="2" Grid.Column="0" Content="7" Command="{Binding CalcDigitCommand}"
                                CommandParameter="7" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="8" Command="{Binding CalcDigitCommand}"
                                CommandParameter="8" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="9" Command="{Binding CalcDigitCommand}"
                                CommandParameter="9" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="2" Grid.Column="3" Content="−" Command="{Binding CalcOpCommand}"
                                CommandParameter="-" Style="{StaticResource CalcOpBtnStyle}"/>

                        <!-- Row 3: 4 5 6 + -->
                        <Button Grid.Row="3" Grid.Column="0" Content="4" Command="{Binding CalcDigitCommand}"
                                CommandParameter="4" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="5" Command="{Binding CalcDigitCommand}"
                                CommandParameter="5" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="6" Command="{Binding CalcDigitCommand}"
                                CommandParameter="6" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="3" Grid.Column="3" Content="+" Command="{Binding CalcOpCommand}"
                                CommandParameter="+" Style="{StaticResource CalcOpBtnStyle}"/>

                        <!-- Row 4: 1 2 3 = -->
                        <Button Grid.Row="4" Grid.Column="0" Content="1" Command="{Binding CalcDigitCommand}"
                                CommandParameter="1" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="4" Grid.Column="1" Content="2" Command="{Binding CalcDigitCommand}"
                                CommandParameter="2" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="4" Grid.Column="2" Content="3" Command="{Binding CalcDigitCommand}"
                                CommandParameter="3" Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="4" Grid.Column="3" Content="=" Command="{Binding CalcEqualsCommand}"
                                Style="{StaticResource CalcEqBtnStyle}"/>

                        <!-- Row 5: 0 (span 2) . OK -->
                        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="0"
                                Command="{Binding CalcDigitCommand}" CommandParameter="0"
                                Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="5" Grid.Column="2" Content="." Command="{Binding CalcDigitCommand}"
                                CommandParameter="." Style="{StaticResource CalcBtnStyle}"/>
                        <Button Grid.Row="5" Grid.Column="3" Content="✓" Command="{Binding CalcEqualsCommand}"
                                Style="{StaticResource CalcEqBtnStyle}"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ===== КАССА ===== -->
            <TextBlock Text="КАССА" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F0F2F5" CornerRadius="10" Padding="3"
                    Margin="0,0,0,18" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding SelectCashCommand}" Cursor="Hand" Height="34" MinWidth="130">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#15803d"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                    CornerRadius="7" Padding="14,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCash}" Value="True">
                                        <Setter Property="Background" Value="#22c55e"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCash}" Value="False">
                                        <Setter Property="Foreground" Value="#15803d"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💵" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Наличные" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectNonCashCommand}" Cursor="Hand" Height="34" MinWidth="130">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#1d4ed8"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                    CornerRadius="7" Padding="14,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNonCash}" Value="True">
                                        <Setter Property="Background" Value="#3b82f6"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsNonCash}" Value="False">
                                        <Setter Property="Foreground" Value="#1d4ed8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Безналичные" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ===== КАТЕГОРИЯ ===== -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="КАТЕГОРИЯ" FontSize="11" FontWeight="SemiBold"
                           Foreground="#98A2B3" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="{Binding ShowMoreLabel}"
                        Command="{Binding ToggleShowAllCategoriesCommand}"
                        Cursor="Hand" FontSize="11" Foreground="#667085"
                        Visibility="{Binding HasMoreCategories, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Padding="4,2">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <ListBox ItemsSource="{Binding VisibleCategories}"
                     SelectedItem="{Binding SelectedCategory}"
                     SelectionMode="Single"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="0,0,0,18"
                     HorizontalContentAlignment="Left"
                     ItemContainerStyle="{StaticResource CategoryChipItemStyle}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" FontSize="12"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ===== ОПИСАНИЕ ===== -->
            <TextBlock Text="ОПИСАНИЕ" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                    Margin="0,0,0,18">
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12"
                         FontSize="13"
                         Background="Transparent"
                         BorderThickness="0"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         Height="54"
                         VerticalContentAlignment="Top"
                         MaxLength="500"
                         Foreground="#344054"
                         TabIndex="5"/>
            </Border>

            <!-- ===== ДАТА ===== -->
            <TextBlock Text="ДАТА" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                    Margin="0,0,0,24" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📅" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding Date}"
                                FontSize="13"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                TabIndex="4"/>
                </StackPanel>
            </Border>

            <!-- ===== SUBMIT BUTTON ===== -->
            <Button Content="{Binding SaveButtonText}"
                    Command="{Binding SaveCommand}"
                    Foreground="White"
                    BorderThickness="0"
                    Height="46"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    TabIndex="6">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#22c55e"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                                            CornerRadius="11" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bg" Property="Background" Value="#CCCCCC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpense}" Value="True">
                                <Setter Property="Background" Value="#ef4444"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <TextBlock Text="Ctrl+Enter — сохранить   ·   Esc — закрыть"
                       FontSize="11" Foreground="#98A2B3"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
