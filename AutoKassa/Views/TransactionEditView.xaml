<UserControl x:Class="AutoKassa.Views.TransactionEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             xmlns:views="clr-namespace:AutoKassa.Views"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>
        <converters:EqualityConverter x:Key="EqualityConverter"/>

        <!-- Style for category chip ListBoxItem -->
        <Style x:Key="CategoryChipItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,7,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="chip"
                                Background="#F0F2F5"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="chip" Property="Background" Value="#1A1D23"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="chip" Property="Background" Value="#E2E5EA"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Calc button style -->
        <Style x:Key="CalcBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#F0F2F5"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E2E5EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#D0D5DD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalcOpBtnStyle" TargetType="Button" BasedOn="{StaticResource CalcBtnStyle}">
            <Setter Property="Background" Value="#E8EAED"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CalcEqBtnStyle" TargetType="Button" BasedOn="{StaticResource CalcBtnStyle}">
            <Setter Property="Background" Value="#22c55e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Thin scrollbar style -->
        <Style x:Key="ThinScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#C8C8C8" CornerRadius="3" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThinVerticalScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ThinScrollBarThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.InputBindings>

    <Grid>
    <!-- Main edit content -->
    <Border Background="White" CornerRadius="16" ClipToBounds="True">
    <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled"
                  Margin="4" Padding="0,0,0,0">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinVerticalScrollBar}"/>
        </ScrollViewer.Resources>
        <StackPanel Margin="28,24,28,28">

            <!-- ===== TITLE + close button ===== -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold"
                           Foreground="#1A1D23" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Command="{Binding CancelCommand}" Cursor="Hand"
                        Width="28" Height="28" ToolTip="Закрыть (Esc)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                <TextBlock Text="✕" FontSize="14" Foreground="#98A2B3"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#F0F2F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ===== TYPE TOGGLE: Расход / Доход ===== -->
            <Border Background="#F0F2F5" CornerRadius="11" Padding="3" Margin="0,0,0,18">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Расход" Command="{Binding SelectExpenseTypeCommand}"
                            Cursor="Hand" Width="190" Height="36">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#667085"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpense}" Value="True">
                                        <Setter Property="Background" Value="#ef4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Доход" Command="{Binding SelectIncomeTypeCommand}"
                            Cursor="Hand" Width="190" Height="36">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#667085"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                        <Setter Property="Background" Value="#22c55e"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ===== AMOUNT BLOCK ===== -->
            <Border Background="#F8F9FB" CornerRadius="14" Padding="18" Margin="0,0,0,18">
                <StackPanel>
                    <!-- Amount input row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AmountTextBox"
                                 Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=False}"
                                 FontSize="32" FontWeight="SemiBold" FontFamily="Consolas"
                                 TextAlignment="Center"
                                 Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Center"
                                 Foreground="#1A1D23"
                                 TabIndex="0"
                                 PreviewTextInput="AmountTextBox_PreviewTextInput"
                                 PreviewKeyDown="AmountTextBox_PreviewKeyDown">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SaveCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <!-- Placeholder -->
                        <TextBlock Text="0"
                                   FontSize="32" FontWeight="SemiBold" FontFamily="Consolas"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#C8CCCF" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AmountText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Calculator toggle button -->
                        <Button x:Name="CalcToggleBtn" Grid.Column="1" Command="{Binding Calculator.ToggleCommand}"
                                Cursor="Hand" Width="34" Height="34" ToolTip="Калькулятор">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="8">
                                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Path x:Name="icon" StrokeThickness="1.8" Fill="Transparent"
                                                      Data="M8 2 H16 A2 2 0 0 1 18 4 V20 A2 2 0 0 1 16 22 H8 A2 2 0 0 1 6 20 V4 A2 2 0 0 1 8 2 Z M9 6 H15 M9 10 H15 M9 14 H12">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Stroke" Value="#98A2B3"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.Calculator.IsOpen, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Stroke" Value="#22c55e"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#F0F2F5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <TextBlock Text="Сумма в рублях" FontSize="11" Foreground="#98A2B3"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding AmountError}"
                               FontSize="12" Foreground="#ef4444" HorizontalAlignment="Center"
                               Margin="0,6,0,0"
                               Visibility="{Binding AmountError, Converter={StaticResource BoolToVisibilityConverter}}"/>

                </StackPanel>
            </Border>

            <!-- ===== КАССА ===== -->
            <TextBlock Text="КАССА" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                <!-- Наличные -->
                <Button Command="{Binding SelectCashCommand}" Cursor="Hand" Height="28">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="2,2,8,2">
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="iconBg" Width="22" Height="22" CornerRadius="4" Margin="0,0,6,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="&#xE901;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White"/>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1D5DB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsCash, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Background" Value="#22c55e"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock x:Name="label" Text="Наличные" FontSize="13" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#667085"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsCash, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Foreground" Value="#1A1D23"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Безналичные -->
                <Button Command="{Binding SelectNonCashCommand}" Cursor="Hand" Height="28" Margin="4,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="2,2,8,2">
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="iconBg" Width="22" Height="22" CornerRadius="4" Margin="0,0,6,0"
                                            VerticalAlignment="Center">
                                        <Viewbox Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M1 4a2 2 0 012-2h18a2 2 0 012 2v14a2 2 0 01-2 2H3a2 2 0 01-2-2z M1 10h22"
                                                      Stroke="White" StrokeThickness="2.2" Fill="Transparent"
                                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1D5DB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsNonCash, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Background" Value="#3b82f6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock x:Name="label" Text="Безналичные" FontSize="13" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#667085"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsNonCash, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Foreground" Value="#1A1D23"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- ===== КАТЕГОРИЯ ===== -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="КАТЕГОРИЯ" FontSize="11" FontWeight="SemiBold"
                           Foreground="#98A2B3" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Command="{Binding OpenCategoryManagerCommand}"
                        Cursor="Hand" ToolTip="Управление категориями"
                        Width="24" Height="24" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="icon"
                                              Data="M12.22 2h-.44a2 2 0 00-2 2v.18a2 2 0 01-1 1.73l-.43.25a2 2 0 01-2 0l-.15-.08a2 2 0 00-2.73.73l-.22.38a2 2 0 00.73 2.73l.15.1a2 2 0 011 1.72v.51a2 2 0 01-1 1.74l-.15.09a2 2 0 00-.73 2.73l.22.38a2 2 0 002.73.73l.15-.08a2 2 0 012 0l.43.25a2 2 0 011 1.73V20a2 2 0 002 2h.44a2 2 0 002-2v-.18a2 2 0 011-1.73l.43-.25a2 2 0 012 0l.15.08a2 2 0 002.73-.73l.22-.39a2 2 0 00-.73-2.73l-.15-.08a2 2 0 01-1-1.74v-.5a2 2 0 011-1.74l.15-.09a2 2 0 00.73-2.73l-.22-.38a2 2 0 00-2.73-.73l-.15.08a2 2 0 01-2 0l-.43-.25a2 2 0 01-1-1.73V4a2 2 0 00-2-2z"
                                              Stroke="#98A2B3" StrokeThickness="2" Fill="Transparent"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Path Data="M12 15a3 3 0 100-6 3 3 0 000 6z"
                                              Stroke="#98A2B3" StrokeThickness="2" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#F0F2F5"/>
                                    <Setter TargetName="icon" Property="Stroke" Value="#667085"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding VisibleCategories}" Margin="0,0,0,18">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Cursor="Hand" Margin="0,0,7,7" FocusVisualStyle="{x:Null}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="chip" CornerRadius="18" Padding="14,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F0F2F5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                <Binding/>
                                                                <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="#1A1D23"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Name}" FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#344054"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="chip" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <!-- "Ещё / Свернуть" chip -->
            <Button Command="{Binding ToggleShowAllCategoriesCommand}"
                    Cursor="Hand" Margin="0,-4,0,18" HorizontalAlignment="Left"
                    Visibility="{Binding HasMoreCategories, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="chip" Background="#EFF6FF" CornerRadius="18" Padding="14,8">
                            <TextBlock Text="{Binding ShowMoreLabel}" FontSize="12" Foreground="#3b82f6"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chip" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ===== ОПИСАНИЕ ===== -->
            <TextBlock Text="ОПИСАНИЕ" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                    Margin="0,0,0,18">
                <Grid>
                    <TextBox x:Name="DescriptionTextBox"
                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Padding="12"
                             FontSize="13"
                             Background="Transparent"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             Height="64"
                             MaxLength="500"
                             Foreground="#344054"
                             TabIndex="5"/>
                    <TextBlock Text="Комментарий..." FontSize="13" Foreground="#98A2B3"
                               Margin="12,0,0,0" VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=DescriptionTextBox}" Value=""/>
                                            <Condition Binding="{Binding IsKeyboardFocused, ElementName=DescriptionTextBox}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ===== ДАТА ===== -->
            <TextBlock Text="ДАТА" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                    Margin="0,0,0,24" Padding="12,10">
                <StackPanel Orientation="Horizontal">
                    <DatePicker SelectedDate="{Binding Date}"
                                FontSize="13"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                TabIndex="4"
                                Padding="0"/>
                    <TextBlock Text="{Binding TodayLabel}" FontSize="13" Foreground="#98A2B3"
                               VerticalAlignment="Center" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- ===== SUBMIT BUTTON ===== -->
            <Button Content="{Binding SaveButtonText}"
                    Command="{Binding SaveCommand}"
                    Foreground="White"
                    BorderThickness="0"
                    Height="46"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    TabIndex="6">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#22c55e"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                                            CornerRadius="11" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bg" Property="Background" Value="#CCCCCC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpense}" Value="True">
                                <Setter Property="Background" Value="#ef4444"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>


        </StackPanel>
    </ScrollViewer>
    </Border>

    <!-- ===== CALCULATOR POPUP ===== -->
    <Popup IsOpen="{Binding Calculator.IsOpen, Mode=TwoWay}"
           PlacementTarget="{x:Reference CalcToggleBtn}"
           Placement="Bottom"
           StaysOpen="False"
           AllowsTransparency="True"
           PopupAnimation="Fade">
        <Border Background="White" CornerRadius="12" Padding="8"
                BorderBrush="#E5E7EB" BorderThickness="1"
                Width="224">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.16" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Display -->
                <Border Grid.Row="0" Grid.ColumnSpan="4"
                        Background="White" CornerRadius="8" Padding="10,6" Margin="2,0,2,6"
                        BorderBrush="#E5E7EB" BorderThickness="1">
                    <TextBlock Text="{Binding Calculator.Display}" FontFamily="Consolas" FontSize="13"
                               Foreground="#1A1D23" TextAlignment="Right" MinHeight="18"
                               TextTrimming="CharacterEllipsis"/>
                </Border>

                <!-- Row 1: C ⌫ ÷ × -->
                <Button Grid.Row="1" Grid.Column="0" Content="C" Command="{Binding Calculator.ClearCommand}"
                        Style="{StaticResource CalcOpBtnStyle}" Foreground="#ef4444"/>
                <Button Grid.Row="1" Grid.Column="1" Content="⌫" Command="{Binding Calculator.BackspaceCommand}"
                        Style="{StaticResource CalcOpBtnStyle}"/>
                <Button Grid.Row="1" Grid.Column="2" Content="÷" Command="{Binding Calculator.OpCommand}"
                        CommandParameter="÷" Style="{StaticResource CalcOpBtnStyle}"/>
                <Button Grid.Row="1" Grid.Column="3" Content="×" Command="{Binding Calculator.OpCommand}"
                        CommandParameter="×" Style="{StaticResource CalcOpBtnStyle}"/>

                <!-- Row 2: 7 8 9 − -->
                <Button Grid.Row="2" Grid.Column="0" Content="7" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="7" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="2" Grid.Column="1" Content="8" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="8" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="2" Grid.Column="2" Content="9" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="9" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="2" Grid.Column="3" Content="−" Command="{Binding Calculator.OpCommand}"
                        CommandParameter="-" Style="{StaticResource CalcOpBtnStyle}"/>

                <!-- Row 3: 4 5 6 + -->
                <Button Grid.Row="3" Grid.Column="0" Content="4" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="4" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="3" Grid.Column="1" Content="5" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="5" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="3" Grid.Column="2" Content="6" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="6" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="3" Grid.Column="3" Content="+" Command="{Binding Calculator.OpCommand}"
                        CommandParameter="+" Style="{StaticResource CalcOpBtnStyle}"/>

                <!-- Row 4: 1 2 3 = -->
                <Button Grid.Row="4" Grid.Column="0" Content="1" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="1" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="4" Grid.Column="1" Content="2" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="2" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="4" Grid.Column="2" Content="3" Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="3" Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="4" Grid.Column="3" Content="=" Command="{Binding Calculator.EqualsCommand}"
                        Style="{StaticResource CalcEqBtnStyle}"/>

                <!-- Row 5: 0 (span 2) . OK -->
                <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="0"
                        Command="{Binding Calculator.DigitCommand}" CommandParameter="0"
                        Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="5" Grid.Column="2" Content="." Command="{Binding Calculator.DigitCommand}"
                        CommandParameter="." Style="{StaticResource CalcBtnStyle}"/>
                <Button Grid.Row="5" Grid.Column="3" Content="✓" Command="{Binding Calculator.EqualsCommand}"
                        Style="{StaticResource CalcEqBtnStyle}"/>
            </Grid>
        </Border>
    </Popup>

    <!-- ===== CATEGORY MANAGER OVERLAY ===== -->
    <Grid Panel.ZIndex="200"
          Visibility="{Binding IsCategoryManagerOpen, Converter={StaticResource BoolToVisibilityConverter}}">
        <Rectangle Fill="#88000000"/>
        <Grid MaxWidth="480" MaxHeight="600"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Margin="8">
            <Border Background="White" CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="24" ShadowDepth="6"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="16" ClipToBounds="True">
                <views:CategoryManagerView DataContext="{Binding CategoryManagerViewModel}"/>
            </Border>
        </Grid>
    </Grid>

    <!-- ===== LOCAL CANCEL TOAST (bottom of form) ===== -->
    <Grid Panel.ZIndex="250"
          VerticalAlignment="Bottom" HorizontalAlignment="Center"
          Margin="0,0,0,20"
          Visibility="{Binding IsCancelToastVisible, Converter={StaticResource BoolToVisibilityConverter}}">
        <Border Background="#1A1D23" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="16" ShadowDepth="3"/>
            </Border.Effect>
        </Border>
        <Border Background="Transparent" CornerRadius="8" Padding="12,8">
            <StackPanel Orientation="Horizontal">
            <TextBlock Text="Отменить изменения?"
                       Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Command="{Binding ConfirmCancelCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="txt" Text="Отменить"
                                   Foreground="#22C55E" FontSize="13" FontWeight="SemiBold"
                                   Padding="4,1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
    </Grid>
    </Grid>
</UserControl>
