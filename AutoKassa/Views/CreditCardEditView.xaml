<UserControl x:Class="AutoKassa.Views.CreditCardEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <!-- Main edit content -->
        <Border Background="White" CornerRadius="16" ClipToBounds="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Margin="4">
                <StackPanel Margin="28,24,28,28">

                    <!-- ===== TITLE + close button ===== -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold"
                                   Foreground="#1A1D23" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Command="{Binding CancelCommand}" Cursor="Hand"
                                Width="28" Height="28" ToolTip="Закрыть (Esc)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                        <TextBlock Text="✕" FontSize="14" Foreground="#98A2B3"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#F0F2F5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- ===== НАЗВАНИЕ КАРТЫ ===== -->
                    <TextBlock Text="НАЗВАНИЕ КАРТЫ" FontSize="11" FontWeight="SemiBold"
                               Foreground="#98A2B3" Margin="0,0,0,8"/>
                    <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                            Margin="0,0,0,4">
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12" FontSize="13" Background="Transparent" BorderThickness="0"/>
                    </Border>
                    <TextBlock Text="{Binding NameError}" FontSize="12" Foreground="#ef4444" Margin="0,0,0,12"
                               Visibility="{Binding NameError, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- ===== БАНК ===== -->
                    <TextBlock Text="БАНК" FontSize="11" FontWeight="SemiBold"
                               Foreground="#98A2B3" Margin="0,0,0,8"/>
                    <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                            Margin="0,0,0,16">
                        <TextBox Text="{Binding BankName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12" FontSize="13" Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- ===== КРЕДИТНЫЙ ЛИМИТ / ТЕКУЩИЙ ДОЛГ ===== -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="КРЕДИТНЫЙ ЛИМИТ" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#98A2B3" Margin="0,0,0,8"/>
                            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1">
                                <TextBox Text="{Binding LimitText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="12" FontSize="13" Background="Transparent" BorderThickness="0"/>
                            </Border>
                            <TextBlock Text="{Binding LimitError}" FontSize="12" Foreground="#ef4444" Margin="0,2,0,0"
                                       Visibility="{Binding LimitError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ТЕКУЩИЙ ДОЛГ" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#98A2B3" Margin="0,0,0,8"/>
                            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1">
                                <TextBox Text="{Binding InitialDebtText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="12" FontSize="13" Background="Transparent" BorderThickness="0"/>
                            </Border>
                            <TextBlock Text="{Binding InitialDebtError}" FontSize="12" Foreground="#ef4444" Margin="0,2,0,0"
                                       Visibility="{Binding InitialDebtError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== СТАВКА / МИН. ПЛАТЁЖ ===== -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="СТАВКА, %" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#98A2B3" Margin="0,0,0,8"/>
                            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1">
                                <TextBox Text="{Binding InterestRateText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="12" FontSize="13" Background="Transparent" BorderThickness="0"/>
                            </Border>
                            <TextBlock Text="{Binding InterestRateError}" FontSize="12" Foreground="#ef4444" Margin="0,2,0,0"
                                       Visibility="{Binding InterestRateError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="МИН. ПЛАТЁЖ, %" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#98A2B3" Margin="0,0,0,8"/>
                            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1">
                                <TextBox Text="{Binding MinimumPaymentPercentText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="12" FontSize="13" Background="Transparent" BorderThickness="0"/>
                            </Border>
                            <TextBlock Text="{Binding MinimumPaymentPercentError}" FontSize="12" Foreground="#ef4444" Margin="0,2,0,0"
                                       Visibility="{Binding MinimumPaymentPercentError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== ДЕНЬ ВЫПИСКИ / ДЕНЬ ПЛАТЕЖА ===== -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ДЕНЬ ВЫПИСКИ" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#98A2B3" Margin="0,0,0,8"/>
                            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1">
                                <TextBox Text="{Binding StatementDayText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="12" FontSize="13" Background="Transparent" BorderThickness="0"/>
                            </Border>
                            <TextBlock Text="{Binding StatementDayError}" FontSize="12" Foreground="#ef4444" Margin="0,2,0,0"
                                       Visibility="{Binding StatementDayError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ДЕНЬ ПЛАТЕЖА" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#98A2B3" Margin="0,0,0,8"/>
                            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1">
                                <TextBox Text="{Binding PaymentDayText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="12" FontSize="13" Background="Transparent" BorderThickness="0"/>
                            </Border>
                            <TextBlock Text="{Binding PaymentDayError}" FontSize="12" Foreground="#ef4444" Margin="0,2,0,0"
                                       Visibility="{Binding PaymentDayError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== АКТИВНА ===== -->
                    <CheckBox IsChecked="{Binding IsActive}" Content="Карта активна"
                              Foreground="#344054" FontSize="13" Margin="0,0,0,24"/>

                    <!-- ===== SUBMIT BUTTON ===== -->
                    <Button Content="Сохранить"
                            Command="{Binding SaveCommand}"
                            Foreground="White"
                            BorderThickness="0"
                            Height="46"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#22c55e"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                    CornerRadius="11" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="bg" Property="Background" Value="#CCCCCC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
