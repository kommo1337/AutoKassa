<UserControl x:Class="AutoKassa.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:vm="clr-namespace:AutoKassa.ViewModels"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             xmlns:views="clr-namespace:AutoKassa.Views"
             Background="{StaticResource ContentBgBrush}"
             FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:OperationTypeToColorConverter x:Key="OperationTypeToColorConverter"/>
        <converters:OperationTypeToTextConverter x:Key="OperationTypeToTextConverter"/>
        <converters:DecimalToStringConverter x:Key="DecimalToStringConverter"/>
        <converters:IsNegativeConverter x:Key="IsNegativeConverter"/>
        <converters:PaymentTypeToIconConverter x:Key="PaymentTypeToIconConverter"/>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>

        <!-- Иконки типа оплаты — Наличные (купюра с кругом) -->
        <DataTemplate x:Key="CashPaymentIconTemplate">
            <Border Background="#F1F5F9" CornerRadius="4" Padding="4,2"
                    ToolTip="Наличные">
                <Viewbox Width="13" Height="13">
                    <Canvas Width="24" Height="24">
                        <Path Data="M1 4a2 2 0 012-2h18a2 2 0 012 2v14a2 2 0 01-2 2H3a2 2 0 01-2-2z"
                              Stroke="#94a3b8" StrokeThickness="2" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Ellipse Canvas.Left="8" Canvas.Top="8" Width="8" Height="8"
                                 Stroke="#94a3b8" StrokeThickness="2" Fill="Transparent"/>
                    </Canvas>
                </Viewbox>
            </Border>
        </DataTemplate>

        <!-- Иконки типа оплаты — Безналичные (карта с полосой) -->
        <DataTemplate x:Key="NonCashPaymentIconTemplate">
            <Border Background="#EFF6FF" CornerRadius="4" Padding="4,2"
                    ToolTip="Безналичные">
                <Viewbox Width="13" Height="13">
                    <Canvas Width="24" Height="24">
                        <Path Data="M1 4a2 2 0 012-2h18a2 2 0 012 2v14a2 2 0 01-2 2H3a2 2 0 01-2-2z M1 10h22"
                              Stroke="#3b82f6" StrokeThickness="2" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>
            </Border>
        </DataTemplate>

        <!-- Стиль переключателя периода -->
        <Style x:Key="PeriodChip" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль контекстного меню -->
        <Style x:Key="ModernContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.12" Direction="270"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="border" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8F9FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- ===== MAIN CONTENT (blurs when modal open) ===== -->
        <Grid x:Name="MainContent">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModalOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="6"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Хедер -->
            <RowDefinition Height="Auto"/>
            <!-- Карточки -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
        </Grid.RowDefinitions>

        <!-- ==================== ХЕДЕР ==================== -->
        <Grid Grid.Row="0" Margin="28,24,28,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Главная"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <!-- Статус-бейдж: баланс за сегодня -->
                <Border CornerRadius="12" Padding="10,5"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#86efac"/>
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F0FFF4" Offset="0"/>
                                        <GradientStop Color="#DCFCE7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasTodayTransactions}" Value="False">
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F8FAFC" Offset="0"/>
                                                <GradientStop Color="#F1F5F9" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TodayBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                    <Setter Property="BorderBrush" Value="#fca5a5"/>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFF5F5" Offset="0"/>
                                                <GradientStop Color="#FFE4E6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTodayTransactions}" Value="False">
                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TodayBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding TodayBalanceFormatted}"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTodayTransactions}" Value="False">
                                            <Setter Property="Text" Value="Нет операций"/>
                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TodayBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Переключатель периода -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="4">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Сегодня" Style="{StaticResource PeriodChip}"
                                 IsChecked="{Binding IsTodaySelected, Mode=OneWay}"
                                 Command="{Binding SelectPeriodCommand}"
                                 CommandParameter="{x:Static vm:PeriodType.Today}"/>
                    <RadioButton Content="Неделя" Style="{StaticResource PeriodChip}"
                                 IsChecked="{Binding IsWeekSelected, Mode=OneWay}"
                                 Command="{Binding SelectPeriodCommand}"
                                 CommandParameter="{x:Static vm:PeriodType.Week}"/>
                    <RadioButton Content="Месяц" Style="{StaticResource PeriodChip}"
                                 IsChecked="{Binding IsMonthSelected, Mode=OneWay}"
                                 Command="{Binding SelectPeriodCommand}"
                                 CommandParameter="{x:Static vm:PeriodType.Month}"/>
                    <RadioButton Content="Год" Style="{StaticResource PeriodChip}"
                                 IsChecked="{Binding IsYearSelected, Mode=OneWay}"
                                 Command="{Binding SelectPeriodCommand}"
                                 CommandParameter="{x:Static vm:PeriodType.Year}"/>
                    <RadioButton Content="Всё время" Style="{StaticResource PeriodChip}"
                                 IsChecked="{Binding IsCustomSelected, Mode=OneWay}"
                                 Command="{Binding SelectPeriodCommand}"
                                 CommandParameter="{x:Static vm:PeriodType.Custom}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Произвольный период -->
        <Border Grid.Row="0" Margin="28,70,28,0" HorizontalAlignment="Right"
                Visibility="{Binding IsCustomPeriodVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="White" CornerRadius="8" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding DateFrom}" Width="110"/>
                <TextBlock Text="По:" VerticalAlignment="Center" Margin="12,0,8,0"/>
                <DatePicker SelectedDate="{Binding DateTo}" Width="110"/>
                <Button Content="Применить" Command="{Binding ApplyCustomPeriodCommand}"
                        Margin="12,0,0,0" Padding="12,6" Background="{StaticResource SidebarBrush}"
                        Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- ==================== КАРТОЧКИ СВОДКИ ==================== -->
        <Grid Grid.Row="1" Margin="28,0,28,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Баланс — с градиентным фоном -->
            <Border Grid.Column="0" Margin="0,0,10,0"
                    CornerRadius="12" Padding="20,20" MinHeight="108">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderThickness" Value="0.8"/>
                        <Setter Property="BorderBrush" Value="#86efac"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F0FFF4" Offset="0"/>
                                    <GradientStop Color="#DCFCE7" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Profit, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                <Setter Property="BorderBrush" Value="#fca5a5"/>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFF5F5" Offset="0"/>
                                            <GradientStop Color="#FFE4E6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- Label БАЛАНС с цветом -->
                    <TextBlock Text="БАЛАНС" FontSize="11" FontWeight="Bold" Margin="0,0,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Profit, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Большая сумма -->
                    <TextBlock FontSize="30" FontWeight="Bold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:N0} ₽">
                                <Binding Path="Profit"/>
                            </MultiBinding>
                        </TextBlock.Text>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Profit, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Доходы -->
            <Border Grid.Column="1" Style="{StaticResource SummaryCard}" Margin="0,0,10,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <!-- Зелёный квадрат со стрелкой вверх -->
                        <Border Width="30" Height="30" Background="#D1FAE5" CornerRadius="8"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 19V5 M5 12L12 5L19 12"
                                          Stroke="#22c55e" StrokeThickness="2.5" Fill="Transparent"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="Доходы" FontSize="13" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="+{0:N0} ₽">
                                <Binding Path="TotalIncome"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Расходы -->
            <Border Grid.Column="2" Style="{StaticResource SummaryCard}" Margin="0,0,10,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <!-- Красный квадрат со стрелкой вниз -->
                        <Border Width="30" Height="30" Background="#FEE2E2" CornerRadius="8"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 5V19 M5 12L12 19L19 12"
                                          Stroke="#ef4444" StrokeThickness="2.5" Fill="Transparent"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="Расходы" FontSize="13" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="-{0:N0} ₽">
                                <Binding Path="TotalExpense"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- За период -->
            <Border Grid.Column="3" CornerRadius="12" Padding="20,20" MinHeight="108">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Border.Background>
                    <SolidColorBrush Color="White"/>
                </Border.Background>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <!-- Синий квадрат с иконкой ℹ️ -->
                        <Border Width="30" Height="30" Background="#DBEAFE" CornerRadius="8"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Canvas.Left="2" Canvas.Top="2" Width="20" Height="20"
                                             Stroke="#3b82f6" StrokeThickness="2" Fill="Transparent"/>
                                    <Path Data="M12 16V12 M12 8L12 8.01"
                                          Stroke="#3b82f6" StrokeThickness="2.5" Fill="Transparent"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="За период" FontSize="13" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Итог за период (Profit) -->
                    <TextBlock FontSize="26" FontWeight="Bold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:N0} ₽">
                                <Binding Path="Profit"/>
                            </MultiBinding>
                        </TextBlock.Text>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Profit, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
        <Grid Grid.Row="2" Margin="28,0,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Лента операций -->
                <ColumnDefinition Width="280"/>
                <!-- Правая панель -->
            </Grid.ColumnDefinitions>

            <!-- ЛЕНТА ОПЕРАЦИЙ СЛЕВА -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,16,24">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок ленты -->
                    <Grid Grid.Row="0" Margin="20,16,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Операции" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Все ›" Foreground="#6366f1"
                                   Cursor="Hand" VerticalAlignment="Center" FontSize="13"
                                   MouseLeftButtonDown="ShowAllTransactions_Click"/>
                    </Grid>

                    <!-- Список групп по датам -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Пустое состояние -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,48,0,0"
                                        Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                <TextBlock Text="Операций пока нет" FontSize="15"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Нажмите + чтобы добавить первую операцию"
                                           FontSize="12" Foreground="#CBD5E1"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Группы по датам -->
                            <ItemsControl ItemsSource="{Binding GroupedTransactions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:DateGroup}">
                                        <StackPanel Margin="0,0,0,4">
                                            <!-- Заголовок дня -->
                                            <Grid Margin="20,12,20,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DateLabel}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource MutedTextBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DayTotalFormatted}"
                                                           FontSize="13" FontWeight="SemiBold">
                                                    <TextBlock.Foreground>
                                                        <Binding Path="DayTotalColor" Converter="{StaticResource CategoryColorConverter}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Grid>

                                            <!-- Строки операций -->
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="Transparent"
                                                                Padding="20,8"
                                                                BorderThickness="0,0,0,1"
                                                                BorderBrush="{StaticResource BorderLightBrush}"
                                                                Cursor="Hand"
                                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                            <Border.ContextMenu>
                                                                <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                                                    <MenuItem Header="Редактировать" Tag="✏️"
                                                                              Style="{StaticResource MenuItemStyle}"
                                                                              Command="{Binding PlacementTarget.Tag.EditTransactionCommand,
                                                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                    <MenuItem Header="Удалить" Tag="🗑️"
                                                                              Style="{StaticResource DeleteMenuItemStyle}"
                                                                              Command="{Binding PlacementTarget.Tag.DeleteTransactionCommand,
                                                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                </ContextMenu>
                                                            </Border.ContextMenu>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <!-- Точка цвета -->
                                                                    <ColumnDefinition Width="*"/>
                                                                    <!-- Название -->
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <!-- Касса -->
                                                                    <ColumnDefinition Width="100"/>
                                                                    <!-- Сумма -->
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Цветная точка категории -->
                                                                <Ellipse Grid.Column="0"
                                                                         Width="8" Height="8"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,10,0">
                                                                    <Ellipse.Fill>
                                                                        <Binding Path="Category.Color" Converter="{StaticResource CategoryColorConverter}"/>
                                                                    </Ellipse.Fill>
                                                                </Ellipse>

                                                                <!-- Категория + описание -->
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Category.Name}"
                                                                               FontSize="13"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                                </StackPanel>

                                                                <!-- Иконка кассы -->
                                                                <ContentControl Grid.Column="2"
                                                                                VerticalAlignment="Center"
                                                                                Margin="12,0,20,0"
                                                                                ToolTip="{Binding PaymentType, Converter={StaticResource PaymentTypeToTextConverter}}">
                                                                    <ContentControl.Style>
                                                                        <Style TargetType="ContentControl">
                                                                            <Setter Property="ContentTemplate" Value="{StaticResource CashPaymentIconTemplate}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding PaymentType}" Value="NonCash">
                                                                                    <Setter Property="ContentTemplate" Value="{StaticResource NonCashPaymentIconTemplate}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ContentControl.Style>
                                                                </ContentControl>

                                                                <!-- Сумма -->
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding Amount, Converter={StaticResource DecimalToStringConverter}}"
                                                                           FontSize="14" FontWeight="SemiBold"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                                    <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ПРАВАЯ ПАНЕЛЬ -->
            <StackPanel Grid.Column="1" Margin="0,0,0,24">

                <!-- Топ расходов -->
                <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Топ расходов" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding TopExpenses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalFormatted}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentRedBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Нет расходов за период" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding TopExpenses.Count, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"
                                   Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- Топ доходов -->
                <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Топ доходов" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding TopIncomes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalFormatted}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentGreenBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Нет доходов за период" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding TopIncomes.Count, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"
                                   Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- Сводка за период -->
                <Border Background="White" CornerRadius="12" Padding="16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Сводка за период" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Операций:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatsCount}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Дней:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatsDays}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сред. расход:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatsAvgExpense, StringFormat={}{0:N0} ₽}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentRedBrush}"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сред. доход:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatsAvgIncome, StringFormat={}{0:N0} ₽}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- ==================== FAB кнопка ==================== -->
        <Button Grid.Row="2"
                Style="{StaticResource FloatingActionButton}"
                Command="{Binding OpenAddTransactionCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,44,40"
                ToolTip="Добавить операцию">
            <TextBlock Text="+" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Margin="0,-1,0,0"/>
        </Button>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="3"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Загрузка..."
                           Margin="0,10,0,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
        </Border>
        </Grid>

        <!-- ===== MODAL OVERLAY ===== -->
        <Grid Panel.ZIndex="100"
              Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- Backdrop -->
            <Rectangle Fill="#66000000"/>

            <!-- Modal card -->
            <Grid MaxWidth="470" MaxHeight="750"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  UseLayoutRounding="True" SnapsToDevicePixels="True">
                <!-- Shadow layer (separate, no children affected) -->
                <Border Background="White" CornerRadius="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.22" BlurRadius="48" ShadowDepth="10" Direction="270"/>
                    </Border.Effect>
                </Border>
                <!-- Content layer (no Effect — text stays crisp) -->
                <Border Background="White" CornerRadius="20" ClipToBounds="True">
                    <views:TransactionEditView DataContext="{Binding EditViewModel}"/>
                </Border>
            </Grid>

        </Grid>

    </Grid>
</UserControl>
