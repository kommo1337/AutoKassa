<UserControl x:Class="AutoKassa.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:vm="clr-namespace:AutoKassa.ViewModels"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             xmlns:views="clr-namespace:AutoKassa.Views"
             Background="{StaticResource ContentBgBrush}"
             FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display">

    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding OpenAddTransactionCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CloseModalCommand}"/>
    </UserControl.InputBindings>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:OperationTypeToColorConverter x:Key="OperationTypeToColorConverter"/>
        <converters:OperationTypeToTextConverter x:Key="OperationTypeToTextConverter"/>
        <converters:DecimalToStringConverter x:Key="DecimalToStringConverter"/>
        <converters:IsNegativeConverter x:Key="IsNegativeConverter"/>
        <converters:PaymentTypeToIconConverter x:Key="PaymentTypeToIconConverter"/>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>

        <!-- Иконки типа оплаты — Наличные (купюра с кругом) -->
        <DataTemplate x:Key="CashPaymentIconTemplate">
            <Border Background="#F1F5F9" CornerRadius="4" Padding="4,2"
                    ToolTip="Наличные">
                <Viewbox Width="13" Height="13">
                    <Canvas Width="24" Height="24">
                        <Path Data="M1 4a2 2 0 012-2h18a2 2 0 012 2v14a2 2 0 01-2 2H3a2 2 0 01-2-2z"
                              Stroke="#94a3b8" StrokeThickness="2" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Ellipse Canvas.Left="8" Canvas.Top="8" Width="8" Height="8"
                                 Stroke="#94a3b8" StrokeThickness="2" Fill="Transparent"/>
                    </Canvas>
                </Viewbox>
            </Border>
        </DataTemplate>

        <!-- Иконки типа оплаты — Безналичные (карта с полосой) -->
        <DataTemplate x:Key="NonCashPaymentIconTemplate">
            <Border Background="#EFF6FF" CornerRadius="4" Padding="4,2"
                    ToolTip="Безналичные">
                <Viewbox Width="13" Height="13">
                    <Canvas Width="24" Height="24">
                        <Path Data="M1 4a2 2 0 012-2h18a2 2 0 012 2v14a2 2 0 01-2 2H3a2 2 0 01-2-2z M1 10h22"
                              Stroke="#3b82f6" StrokeThickness="2" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>
            </Border>
        </DataTemplate>

        <!-- Иконки типа оплаты — Кредитная карта -->
        <DataTemplate x:Key="CreditCardPaymentIconTemplate">
            <Border Background="#F5F3FF" CornerRadius="4" Padding="4,2"
                    ToolTip="Кредит">
                <Viewbox Width="13" Height="13">
                    <Canvas Width="24" Height="24">
                        <Path Data="M1 4a2 2 0 012-2h18a2 2 0 012 2v14a2 2 0 01-2 2H3a2 2 0 01-2-2z M1 10h22"
                              Stroke="#6366f1" StrokeThickness="2" Fill="Transparent"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>
            </Border>
        </DataTemplate>

        <!-- Стиль контекстного меню -->
        <Style x:Key="ModernContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.12" Direction="270"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="border" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8F9FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid x:Name="MainContent">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Хедер -->
            <RowDefinition Height="Auto"/>
            <!-- Карточки -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
        </Grid.RowDefinitions>

        <!-- ==================== ХЕДЕР ==================== -->
        <Grid Grid.Row="0" Margin="28,24,28,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Главная"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <!-- Статус-бейдж: баланс за сегодня -->
                <Border CornerRadius="12" Padding="10,5"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        BorderThickness="1"
                        ToolTip="Итого за сегодня">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#86efac"/>
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F0FFF4" Offset="0"/>
                                        <GradientStop Color="#DCFCE7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasTodayTransactions}" Value="False">
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F8FAFC" Offset="0"/>
                                                <GradientStop Color="#F1F5F9" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TodayBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                    <Setter Property="BorderBrush" Value="#fca5a5"/>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFF5F5" Offset="0"/>
                                                <GradientStop Color="#FFE4E6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTodayTransactions}" Value="False">
                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TodayBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding TodayBalanceFormatted}"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTodayTransactions}" Value="False">
                                            <Setter Property="Text" Value="Нет операций"/>
                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TodayBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Переключатель периода -->
            <Grid Grid.Column="2">
                <Button x:Name="PeriodBtn"
                        Command="{Binding TogglePeriodPickerCommand}"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#F8F9FB"
                                    BorderBrush="#E8EAED" BorderThickness="1"
                                    CornerRadius="9" Padding="11,8">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="13" Height="13" Margin="0,0,5,0" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Stroke="#98A2B3" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"
                                                  Data="M 5,4 L 19,4 A 2,2 0 0 1 21,6 L 21,20 A 2,2 0 0 1 19,22 L 5,22 A 2,2 0 0 1 3,20 L 3,6 A 2,2 0 0 1 5,4 Z"/>
                                            <Line X1="16" Y1="2" X2="16" Y2="6" Stroke="#98A2B3" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="8" Y1="2" X2="8" Y2="6" Stroke="#98A2B3" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="3" Y1="10" X2="21" Y2="10" Stroke="#98A2B3" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="{Binding PeriodButtonLabel}" FontSize="12" Foreground="#344054" VerticalAlignment="Center"/>
                                    <TextBlock Text=" ▾" FontSize="10" Foreground="#98A2B3" VerticalAlignment="Center"/>
                                </StackPanel>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="MouseOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bd"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0">
                                                        <DiscreteObjectKeyFrame.Value>
                                                            <SolidColorBrush Color="#F0F2F5"/>
                                                        </DiscreteObjectKeyFrame.Value>
                                                    </DiscreteObjectKeyFrame>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Popup IsOpen="{Binding IsPeriodPickerOpen}"
                       StaysOpen="False"
                       PlacementTarget="{Binding ElementName=PeriodBtn}"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="White" BorderBrush="#E8EAED" BorderThickness="1"
                            CornerRadius="14" Padding="16"
                            MinWidth="310" Margin="0,6,0,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="24" ShadowDepth="8" Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Раздел: быстрый выбор -->
                            <TextBlock Text="БЫСТРЫЙ ВЫБОР" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#98A2B3" Margin="0,0,0,10"/>
                            <WrapPanel Margin="0,0,0,16">
                                <Button Content="Сегодня" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static vm:PeriodType.Today}"
                                        Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                <Button Content="Неделя" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static vm:PeriodType.Week}"
                                        Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                <Button Content="Месяц" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static vm:PeriodType.Month}"
                                        Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                <Button Content="Год" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static vm:PeriodType.Year}"
                                        Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                <Button Content="Всё время" Command="{Binding SelectPeriodCommand}" CommandParameter="{x:Static vm:PeriodType.AllTime}"
                                        Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                            </WrapPanel>

                            <!-- Раздел: произвольный период -->
                            <TextBlock Text="ПРОИЗВОЛЬНЫЙ ПЕРИОД" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#98A2B3" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <!-- Дата от -->
                                <Grid>
                                    <DatePicker x:Name="DateFromPicker"
                                                SelectedDate="{Binding DateFrom}"
                                                Width="118" FontSize="12"/>
                                    <TextBlock Text="Дата от" Foreground="#C0C5D0"
                                               FontSize="12" VerticalAlignment="Center"
                                               Margin="9,0,0,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DateFrom}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <TextBlock Text="—" Foreground="#D0D5DD" FontSize="14"
                                           VerticalAlignment="Center" Margin="8,0"/>

                                <!-- Дата до -->
                                <Grid>
                                    <DatePicker x:Name="DateToPicker"
                                                SelectedDate="{Binding DateTo}"
                                                Width="118" FontSize="12"/>
                                    <TextBlock Text="Дата до" Foreground="#C0C5D0"
                                               FontSize="12" VerticalAlignment="Center"
                                               Margin="9,0,0,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DateTo}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <!-- Применить -->
                            <Button Content="Применить" Command="{Binding ApplyCustomPeriodCommand}"
                                    Margin="0,12,0,0" Height="34" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btn" Background="#22c55e" CornerRadius="10">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       Foreground="White" FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btn" Property="Background" Value="#16a34a"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>

        <!-- ==================== КАРТОЧКИ СВОДКИ ==================== -->
        <Grid Grid.Row="1" Margin="28,0,28,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Баланс — с градиентным фоном -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <!-- Shadow layer -->
                <Border CornerRadius="12" Padding="20,20" MinHeight="108">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="0.8"/>
                            <Setter Property="BorderBrush" Value="#86efac"/>
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F0FFF4" Offset="0"/>
                                        <GradientStop Color="#DCFCE7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentCashBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                    <Setter Property="BorderBrush" Value="#fca5a5"/>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFF5F5" Offset="0"/>
                                                <GradientStop Color="#FFE4E6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <!-- Content layer -->
                <Border CornerRadius="12" Padding="20,20" MinHeight="108" Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="0.8"/>
                            <Setter Property="BorderBrush" Value="#86efac"/>
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F0FFF4" Offset="0"/>
                                        <GradientStop Color="#DCFCE7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentCashBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                    <Setter Property="BorderBrush" Value="#fca5a5"/>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFF5F5" Offset="0"/>
                                                <GradientStop Color="#FFE4E6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <!-- Label БАЛАНС -->
                        <TextBlock Text="БАЛАНС" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <!-- Большая сумма -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="30" FontWeight="Bold"
                                       Text="{Binding CurrentCashBalance, StringFormat='{}{0:N0}'}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentCashBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text=" ₽" FontSize="20" FontWeight="Bold" Opacity="0.5"
                                       VerticalAlignment="Bottom" Margin="0,0,0,3">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentCashBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <!-- Разбивка Наличные / Безналичные -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <ContentControl ContentTemplate="{StaticResource CashPaymentIconTemplate}" VerticalAlignment="Center"/>
                            <TextBlock Text="Наличные:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center" Margin="6,0,6,0"/>
                            <TextBlock Text="{Binding CashBalance, StringFormat='{}{0:N0} ₽'}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ContentControl ContentTemplate="{StaticResource NonCashPaymentIconTemplate}" VerticalAlignment="Center"/>
                            <TextBlock Text="Безналичные:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center" Margin="6,0,6,0"/>
                            <TextBlock Text="{Binding NonCashBalance, StringFormat='{}{0:N0} ₽'}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Доходы -->
            <Grid Grid.Column="1" Margin="0,0,10,0">
                <Border Style="{StaticResource SummaryCard}"/>
                <Border Style="{StaticResource SummaryCard}" Background="Transparent">
                <StackPanel>
                    <TextBlock Text="ДОХОДЫ" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="30" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}"
                                   Text="{Binding TotalIncome, StringFormat='+{0:N0}'}"/>
                        <TextBlock Text=" ₽" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}"
                                   Opacity="0.5" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <ContentControl ContentTemplate="{StaticResource CashPaymentIconTemplate}" VerticalAlignment="Center"/>
                        <TextBlock Text="Наличные:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="6,0,6,0"/>
                        <TextBlock Text="{Binding CashIncome, StringFormat='+{0:N0} ₽'}"
                                   FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ContentControl ContentTemplate="{StaticResource NonCashPaymentIconTemplate}" VerticalAlignment="Center"/>
                        <TextBlock Text="Безналичные:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="6,0,6,0"/>
                        <TextBlock Text="{Binding NonCashIncome, StringFormat='+{0:N0} ₽'}"
                                   FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            </Grid>

            <!-- Расходы -->
            <Grid Grid.Column="2" Margin="0,0,10,0">
                <Border Style="{StaticResource SummaryCard}"/>
                <Border Style="{StaticResource SummaryCard}" Background="Transparent">
                <StackPanel>
                    <TextBlock Text="РАСХОДЫ" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="30" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}"
                                   Text="{Binding TotalExpense, StringFormat='-{0:N0}'}"/>
                        <TextBlock Text=" ₽" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}"
                                   Opacity="0.5" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <ContentControl ContentTemplate="{StaticResource CashPaymentIconTemplate}" VerticalAlignment="Center"/>
                        <TextBlock Text="Наличные:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="6,0,6,0"/>
                        <TextBlock Text="{Binding CashExpense, StringFormat='-{0:N0} ₽'}"
                                   FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ContentControl ContentTemplate="{StaticResource NonCashPaymentIconTemplate}" VerticalAlignment="Center"/>
                        <TextBlock Text="Безналичные:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="6,0,6,0"/>
                        <TextBlock Text="{Binding NonCashExpense, StringFormat='-{0:N0} ₽'}"
                                   FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            </Grid>

            <!-- За период -->
            <Grid Grid.Column="3">
                <Border Style="{StaticResource SummaryCard}"/>
                <Border Style="{StaticResource SummaryCard}" Background="Transparent">
                    <StackPanel>
                        <TextBlock Text="{Binding PeriodLabel}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <!-- Итог за период (Profit) -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="30" FontWeight="Bold"
                                       Text="{Binding Profit, StringFormat='{}{0:N0}'}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Profit, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text=" ₽" FontSize="20" FontWeight="Bold" Opacity="0.5"
                                       VerticalAlignment="Bottom" Margin="0,0,0,3">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Profit, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <ContentControl ContentTemplate="{StaticResource CashPaymentIconTemplate}" VerticalAlignment="Center"/>
                            <TextBlock Text="Наличные:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center" Margin="6,0,6,0"/>
                            <TextBlock Text="{Binding CashProfit, StringFormat='{}{0:N0} ₽'}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ContentControl ContentTemplate="{StaticResource NonCashPaymentIconTemplate}" VerticalAlignment="Center"/>
                            <TextBlock Text="Безналичные:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center" Margin="6,0,6,0"/>
                            <TextBlock Text="{Binding NonCashProfit, StringFormat='{}{0:N0} ₽'}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
        <Grid Grid.Row="2" Margin="28,0,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Лента операций -->
                <ColumnDefinition Width="280"/>
                <!-- Правая панель -->
            </Grid.ColumnDefinitions>

            <!-- ЛЕНТА ОПЕРАЦИЙ СЛЕВА -->
            <Grid Grid.Column="0" Margin="0,0,16,24">
                <Border Background="White" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                </Border>
                <Border Background="Transparent" CornerRadius="12" ClipToBounds="True">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок ленты -->
                    <Grid Grid.Row="0" Margin="20,16,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Операции" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Все ›" Foreground="#6366f1"
                                   Cursor="Hand" VerticalAlignment="Center" FontSize="13"
                                   MouseLeftButtonDown="ShowAllTransactions_Click"/>
                    </Grid>

                    <!-- Список групп по датам -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!-- Пустое состояние -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,48,0,0"
                                        Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                <TextBlock Text="Операций пока нет" FontSize="15"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Нажмите + чтобы добавить первую операцию"
                                           FontSize="12" Foreground="#CBD5E1"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- Группы по датам — ListBox с виртуализацией для производительности -->
                            <ListBox ItemsSource="{Binding GroupedTransactions}"
                                     Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVisibilityConverter}}"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Focusable="False"
                                     BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:DateGroup}">
                                        <StackPanel Margin="0,0,0,4">
                                            <!-- Заголовок дня -->
                                            <Border Background="#F8F9FB" BorderBrush="#F0F2F5" BorderThickness="0,0,0,1">
                                                <Grid Margin="20,9,20,7">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DateLabel}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#344054"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding DayTotalFormatted}"
                                                               FontSize="13" FontWeight="SemiBold">
                                                        <TextBlock.Foreground>
                                                            <Binding Path="DayTotalColor" Converter="{StaticResource CategoryColorConverter}"/>
                                                        </TextBlock.Foreground>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>

                                            <!-- Строки операций -->
                                            <ItemsControl ItemsSource="{Binding Items}"
                                                          VirtualizingPanel.IsVirtualizing="True"
                                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="Transparent"
                                                                Padding="20,8"
                                                                BorderThickness="0,0,0,1"
                                                                BorderBrush="{StaticResource BorderLightBrush}"
                                                                Cursor="Hand"
                                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                MouseLeftButtonDown="TransactionItem_MouseLeftButtonDown">
                                                            <Border.ContextMenu>
                                                                <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                                                    <MenuItem Header="Редактировать" Tag="✏️"
                                                                              Style="{StaticResource MenuItemStyle}"
                                                                              Command="{Binding PlacementTarget.Tag.EditTransactionCommand,
                                                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                    <MenuItem Header="Удалить" Tag="🗑️"
                                                                              Style="{StaticResource DeleteMenuItemStyle}"
                                                                              Command="{Binding PlacementTarget.Tag.DeleteTransactionCommand,
                                                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                </ContextMenu>
                                                            </Border.ContextMenu>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <!-- Точка цвета -->
                                                                    <ColumnDefinition Width="*"/>
                                                                    <!-- Название -->
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <!-- Касса -->
                                                                    <ColumnDefinition Width="100"/>
                                                                    <!-- Сумма -->
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Цветная точка категории -->
                                                                <Ellipse Grid.Column="0"
                                                                         Width="8" Height="8"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,10,0">
                                                                    <Ellipse.Fill>
                                                                        <Binding Path="Category.Color" Converter="{StaticResource CategoryColorConverter}"/>
                                                                    </Ellipse.Fill>
                                                                </Ellipse>

                                                                <!-- Категория + описание -->
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Category.Name}"
                                                                               FontSize="13"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                                </StackPanel>

                                                                <!-- Иконка кассы -->
                                                                <ContentControl Grid.Column="2"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,20,0"
                                                                                ToolTip="{Binding PaymentType, Converter={StaticResource PaymentTypeToTextConverter}}">
                                                                    <ContentControl.Style>
                                                                        <Style TargetType="ContentControl">
                                                                            <Setter Property="ContentTemplate" Value="{StaticResource CashPaymentIconTemplate}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding PaymentType}" Value="NonCash">
                                                                                    <Setter Property="ContentTemplate" Value="{StaticResource NonCashPaymentIconTemplate}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding PaymentType}" Value="CreditCard">
                                                                                    <Setter Property="ContentTemplate" Value="{StaticResource CreditCardPaymentIconTemplate}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ContentControl.Style>
                                                                </ContentControl>

                                                                <!-- Сумма -->
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding Amount, Converter={StaticResource DecimalToStringConverter}}"
                                                                           FontSize="14" FontWeight="SemiBold"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                                    <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </ScrollViewer>
                </Grid>
                </Border>
            </Grid>

            <!-- ПРАВАЯ ПАНЕЛЬ -->
            <StackPanel Grid.Column="1" Margin="0,0,0,24">

                <!-- Виджет кредитной карты -->
                <Grid Margin="0,0,0,12"
                      Visibility="{Binding HasCreditCards, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Background="White" CornerRadius="12">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                        </Border.Effect>
                    </Border>
                    <Border Background="Transparent" CornerRadius="12" Padding="16" ClipToBounds="True">
                        <StackPanel>
                            <TextBlock Text="Кредитная карта" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Кредитный лимит" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalCreditLimitFormatted}"
                                           FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TotalCreditUsedFormatted}"
                                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalCreditAvailableFormatted}"
                                           FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}"
                                           VerticalAlignment="Bottom"/>
                            </Grid>

                            <ProgressBar Value="{Binding TotalCreditUsed}" Maximum="{Binding TotalCreditLimit}"
                                         Height="6" BorderThickness="0" Background="#E2E8F0" Foreground="#6366f1"
                                         Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Текущий долг" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalCreditDebtFormatted}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ближайший платёж" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding NextCreditPaymentDateFormatted}"
                                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding NextCreditPaymentAmountFormatted}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Топ расходов -->
                <Grid Margin="0,0,0,12">
                    <Border Background="White" CornerRadius="12">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                        </Border.Effect>
                    </Border>
                    <Border Background="Transparent" CornerRadius="12" Padding="16" ClipToBounds="True">
                        <StackPanel>
                            <TextBlock Text="Топ расходов" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding TopExpenses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalFormatted}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentRedBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Нет расходов за период" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding TopExpenses.Count, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"
                                   Margin="0,8"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Топ доходов -->
                <Grid Margin="0,0,0,12">
                    <Border Background="White" CornerRadius="12">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                        </Border.Effect>
                    </Border>
                    <Border Background="Transparent" CornerRadius="12" Padding="16" ClipToBounds="True">
                        <StackPanel>
                            <TextBlock Text="Топ доходов" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding TopIncomes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalFormatted}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentGreenBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Нет доходов за период" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding TopIncomes.Count, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"
                                   Margin="0,8"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Сводка за период -->
                <Grid>
                    <Border Background="White" CornerRadius="12">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                        </Border.Effect>
                    </Border>
                    <Border Background="Transparent" CornerRadius="12" Padding="16" ClipToBounds="True">
                        <StackPanel>
                            <TextBlock Text="Сводка за период" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Операций:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatsCount}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Дней:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatsDays}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сред. расход:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatsAvgExpense, StringFormat={}{0:N0} ₽}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentRedBrush}"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сред. доход:" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatsAvgIncome, StringFormat={}{0:N0} ₽}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreenBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            </StackPanel>
        </Grid>

        <!-- Индикатор загрузки -->
        <Border Grid.RowSpan="3"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Загрузка..."
                           Margin="0,10,0,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
        </Border>
        </Grid>

        <!-- ===== FAB ===== -->
        <Button Command="{Binding OpenAddTransactionCommand}"
                Width="52" Height="52"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,28,38"
                Cursor="Hand"
                ToolTip="Добавить операцию (Ctrl+N)"
                Panel.ZIndex="50">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="fab" Background="#22c55e" CornerRadius="15">
                        <Border.Effect>
                            <DropShadowEffect Color="#22c55e" BlurRadius="18" ShadowDepth="4" Opacity="0.35"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="fab"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#16a34a" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <TextBlock Text="+" FontSize="28" Foreground="White" FontWeight="Light"
                       Margin="0,-2,0,0" VerticalAlignment="Center"/>
        </Button>

        <!-- ===== MODAL OVERLAY ===== -->
        <Grid Panel.ZIndex="100"
              Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- Backdrop -->
            <Rectangle Fill="#66000000"/>

            <!-- Modal card -->
            <Grid MaxWidth="470" MinHeight="775" MaxHeight="775"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  UseLayoutRounding="True" SnapsToDevicePixels="True">
                <!-- Shadow layer (separate, no children affected) -->
                <Border Background="White" CornerRadius="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.22" BlurRadius="24" ShadowDepth="10" Direction="270"/>
                    </Border.Effect>
                </Border>
                <!-- Content layer (no Effect — text stays crisp) -->
                <Border Background="White" CornerRadius="20" ClipToBounds="True">
                    <views:TransactionEditView DataContext="{Binding EditViewModel}"/>
                </Border>
            </Grid>

        </Grid>

    </Grid>
</UserControl>
