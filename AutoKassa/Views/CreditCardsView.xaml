<UserControl x:Class="AutoKassa.Views.CreditCardsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AutoKassa.ViewModels"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             Background="{StaticResource ContentBgBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- MAIN CONTENT -->
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Кредитные карты" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="+ Добавить карту" Command="{Binding AddCommand}"
                        Padding="14,8" FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="#6366f1" CornerRadius="10">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- SUMMARY CARDS -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SummaryCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="ОБЩИЙ ЛИМИТ" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalLimitFormatted}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SummaryCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="ТЕКУЩИЙ ДОЛГ" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalDebtFormatted}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AccentRedBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SummaryCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="ДОСТУПНО" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalAvailableFormatted}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource SummaryCard}">
                    <StackPanel>
                        <TextBlock Text="БЛИЖАЙШИЙ ПЛАТЁЖ" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding NearestPaymentAmountFormatted}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding NearestPaymentDateFormatted}" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- CARDS LIST -->
                <Border Grid.Column="0" Background="White" CornerRadius="14" Margin="0,0,16,0"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ListBox ItemsSource="{Binding CreditCardItems}"
                                     SelectedItem="{Binding SelectedCardItem}"
                                     BorderThickness="0" Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.Resources>
                                    <!-- Стиль кнопки редактирования карты -->
                                    <Style x:Key="CardEditButtonStyle" TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Width" Value="32"/>
                                        <Setter Property="Height" Value="32"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="5">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#F0F2F5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <!-- Стиль кнопки удаления карты -->
                                    <Style x:Key="CardDeleteButtonStyle" TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Width" Value="32"/>
                                        <Setter Property="Height" Value="32"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="5">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#FFEBEE"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.Resources>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="16"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="bd" Background="Transparent" Padding="16,8,16,0">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#F5F3FF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#F8F9FB"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CreditCardListItemViewModel}">
                                        <Border Style="{StaticResource SummaryCard}"
                                                BorderBrush="{StaticResource BorderLightBrush}"
                                                BorderThickness="1"
                                                Padding="20">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Заголовок карточки -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Иконка карты -->
                                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12"
                                                            Background="#EEF2FF" Margin="0,0,14,0"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Canvas Width="24" Height="24">
                                                                <Path Data="M3 10h18M7 15h1m4 0h1m-7 4h12a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                                                      Stroke="#6366f1" StrokeThickness="2" Fill="Transparent"
                                                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Border>

                                                    <!-- Название и банк -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Card.Name}" FontSize="16" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Card.BankName}" FontSize="12"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   Visibility="{Binding Card.BankName, Converter={StaticResource StringToVisibilityConverter}}"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- Кнопки действий -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand"
                                                                Style="{StaticResource CardEditButtonStyle}"
                                                                ToolTip="Редактировать">
                                                            <Viewbox Width="16" Height="16">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path Data="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7 M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"
                                                                          Stroke="#667085" StrokeThickness="2" Fill="Transparent"
                                                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Button>
                                                        <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand"
                                                                Style="{StaticResource CardDeleteButtonStyle}"
                                                                ToolTip="Деактивировать"
                                                                Margin="4,0,0,0">
                                                            <Viewbox Width="16" Height="16">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path Data="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14"
                                                                          Stroke="#9ca3af" StrokeThickness="2" Fill="Transparent"
                                                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Сетка метрик -->
                                                <Grid Grid.Row="1" Margin="0,20,0,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,14">
                                                        <TextBlock Text="Лимит" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Card.Limit, StringFormat='{}{0:N0} ₽'}" FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,16,14">
                                                        <TextBlock Text="Долг" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding CurrentDebtFormatted}" FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentRedBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                                                        <TextBlock Text="Доступно" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding AvailableLimitFormatted}" FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentGreenBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                                                        <TextBlock Text="Мин. платёж" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding MinimumPaymentFormatted}" FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,0">
                                                        <TextBlock Text="Следующий платёж" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding NextPaymentDateFormatted}" FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,0">
                                                        <TextBlock Text="Ставка" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding InterestRateFormatted}" FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding HasCards, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                            <TextBlock Text="Карт пока нет" FontSize="15" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Text="Нажмите «+ Добавить карту»" FontSize="12" Foreground="#CBD5E1"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- PURCHASES PANEL -->
                <Border Grid.Column="1" Background="White" CornerRadius="14"
                        BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="История покупок" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="16,16,16,12"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedCardPurchases}" Margin="16,0,16,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F0F2F5" BorderThickness="0,0,0,1" Padding="0,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{Binding Transaction.Category.Name}"
                                                           FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           Text="{Binding Amount, StringFormat='{}{0:N0} ₽'}"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                           Text="{Binding PurchaseDate, StringFormat='{}{0:dd.MM.yyyy}'}"
                                                           FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Grid.Row="1" Text="Выберите карту" FontSize="13" Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding SelectedCardItem, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- LOADING OVERLAY -->
        <Border Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Загрузка..." Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
        </Border>

        <!-- MODAL OVERLAY -->
        <Grid Panel.ZIndex="200"
              Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Rectangle Fill="#88000000"/>
            <Border Background="White" CornerRadius="16" MaxWidth="520"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="24" ShadowDepth="6"/>
                </Border.Effect>
                <views:CreditCardEditView DataContext="{Binding EditViewModel}"
                                          xmlns:views="clr-namespace:AutoKassa.Views"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
