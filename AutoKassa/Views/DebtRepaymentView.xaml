<UserControl x:Class="AutoKassa.Views.DebtRepaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             xmlns:enums="clr-namespace:AutoKassa.Models.Enums"
             Background="Transparent">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:PaymentTypeToTextConverter x:Key="PaymentTypeToTextConverter"/>
    </UserControl.Resources>

    <Grid MaxWidth="420" MinWidth="280" Margin="28" HorizontalAlignment="Center">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock FontSize="13" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,24">
                <Run Text="Остаток: "/>
                <Run Text="{Binding Debt.RemainingAmount, StringFormat=N2, Mode=OneWay}" FontWeight="SemiBold"/>
                <Run Text=" ₽"/>
            </TextBlock>

            <!-- AMOUNT -->
            <TextBlock Text="СУММА ПОГАШЕНИЯ" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
            <Border Background="{StaticResource ContentBgBrush}" CornerRadius="11" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                    Margin="0,0,0,16">
                <TextBox x:Name="AmountTextBox"
                         Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12" FontSize="18" FontWeight="SemiBold" Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Center"
                         PreviewTextInput="AmountTextBox_PreviewTextInput"/>
            </Border>
            <TextBlock Text="{Binding AmountError}" FontSize="12" Foreground="{StaticResource AccentRedBrush}"
                       Margin="0,-12,0,16"
                       Visibility="{Binding AmountError, Converter={StaticResource StringToVisibilityConverter}}"/>

            <!-- PAYMENT TYPE -->
            <TextBlock Text="ТИП ОПЛАТЫ" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
            <ComboBox SelectedItem="{Binding PaymentType}" Margin="0,0,0,16" Padding="12,10" FontSize="14">
                <enums:PaymentType>Cash</enums:PaymentType>
                <enums:PaymentType>NonCash</enums:PaymentType>
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource PaymentTypeToTextConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- DATE -->
            <TextBlock Text="ДАТА" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
            <DatePicker SelectedDate="{Binding Date}" FontSize="13" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding DateError}" FontSize="12" Foreground="{StaticResource AccentRedBrush}"
                       Margin="0,0,0,12"
                       Visibility="{Binding DateError, Converter={StaticResource StringToVisibilityConverter}}"/>

            <!-- DESCRIPTION -->
            <TextBlock Text="ОПИСАНИЕ" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
            <Border Background="{StaticResource ContentBgBrush}" CornerRadius="11" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                    Margin="0,0,0,24">
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12" FontSize="14" Background="Transparent" BorderThickness="0"
                         TextWrapping="Wrap" AcceptsReturn="False" Height="64" MaxLength="500"/>
            </Border>

            <!-- BUTTONS -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Отмена" Command="{Binding CancelCommand}"
                        Margin="0,0,8,0" Padding="12" FontSize="14" FontWeight="SemiBold"
                        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextSecondaryBrush}" BorderThickness="0" Cursor="Hand"/>
                <Button Grid.Column="1" Content="Погасить" Command="{Binding RepayCommand}"
                        Margin="8,0,0,0" Padding="12" FontSize="14" FontWeight="SemiBold"
                        Background="{StaticResource AccentGreenBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
