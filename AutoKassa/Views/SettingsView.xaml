<UserControl x:Class="AutoKassa.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>

        <!-- Вкладка боковой навигации -->
        <Style x:Key="SettingsTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DCFCE7"/>
                                <Setter Property="Foreground" Value="#16a34a"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F3F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Карточка секции -->
        <Style x:Key="SettingsSectionStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Заголовок секции -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Строка настройки -->
        <Style x:Key="SettingRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- Вторичная кнопка действия -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F1F3F5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8EAED"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кастомный CheckBox — зелёный -->
        <Style x:Key="GreenCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="bd"
                                Width="20" Height="20"
                                CornerRadius="6"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="1.5"
                                Background="White">
                            <TextBlock x:Name="chk"
                                       Text="✓"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBgBrush}"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,0">
            <Grid Height="60">
                <TextBlock Text="Настройки"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Сохранить"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PillButton}"
                            Padding="20,8"
                            Margin="0,0,10,0"/>
                    <Button Content="Отмена"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource ActionButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Grid.Row="1" Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="188"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковая навигация -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBgBrush}"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,0,20,0"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <RadioButton Content="Общие"            Style="{StaticResource SettingsTabStyle}" IsChecked="True" GroupName="SettingsTabs"/>
                        <RadioButton Content="Операции"         Style="{StaticResource SettingsTabStyle}" GroupName="SettingsTabs"/>
                        <RadioButton Content="Отчёты"           Style="{StaticResource SettingsTabStyle}" GroupName="SettingsTabs"/>
                        <RadioButton Content="Резерв. копир."   Style="{StaticResource SettingsTabStyle}" GroupName="SettingsTabs"/>
                        <RadioButton Content="Безопасность"     Style="{StaticResource SettingsTabStyle}" GroupName="SettingsTabs"/>
                        <RadioButton Content="Интерфейс"        Style="{StaticResource SettingsTabStyle}" GroupName="SettingsTabs"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <Rectangle Height="1" Fill="{StaticResource BorderLightBrush}" Margin="4,0,4,12"/>
                        <Button Content="Экспорт"
                                Command="{Binding ExportCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"/>
                        <Button Content="Импорт"
                                Command="{Binding ImportCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"/>
                        <Button Content="Сброс настроек"
                                Command="{Binding ResetCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Foreground="{StaticResource AccentRedBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Контент секций -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Общие -->
                    <Border Style="{StaticResource SettingsSectionStyle}">
                        <StackPanel>
                            <TextBlock Text="Общие настройки" Style="{StaticResource SectionHeaderStyle}"/>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Автоблокировка экрана" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Блокировать приложение при неактивности"
                                               FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding AutoLockEnabled}" Style="{StaticResource GreenCheckBoxStyle}"/>
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Время неактивности (мин)" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding AutoLockMinutes, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" TextAlignment="Center"/>
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Показывать уведомления" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding ShowNotifications}" Style="{StaticResource GreenCheckBoxStyle}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Тема оформления" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AvailableThemes}"
                                          SelectedItem="{Binding SelectedTheme}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Операции -->
                    <Border Style="{StaticResource SettingsSectionStyle}">
                        <StackPanel>
                            <TextBlock Text="Настройки операций" Style="{StaticResource SectionHeaderStyle}"/>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Показывать «Категории» в меню" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Добавить кнопку Категории в боковое меню"
                                               FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding ShowOperationsInSidebar}" Style="{StaticResource GreenCheckBoxStyle}"/>
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Записей на странице" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding DefaultPageSize, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" TextAlignment="Center"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Подтверждать удаление" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding ConfirmDelete}" Style="{StaticResource GreenCheckBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Отчёты -->
                    <Border Style="{StaticResource SettingsSectionStyle}">
                        <StackPanel>
                            <TextBlock Text="Настройки отчётов" Style="{StaticResource SectionHeaderStyle}"/>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Период по умолчанию" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AvailablePeriods}"
                                          SelectedItem="{Binding SelectedDefaultPeriod}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Автоматически формировать отчёты" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding AutoGenerateReports}" Style="{StaticResource GreenCheckBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Резервное копирование -->
                    <Border Style="{StaticResource SettingsSectionStyle}">
                        <StackPanel>
                            <TextBlock Text="Резервное копирование" Style="{StaticResource SectionHeaderStyle}"/>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Автоматическое резервное копирование" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding BackupEnabled}" Style="{StaticResource GreenCheckBoxStyle}"/>
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Интервал (дней)" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding AutoBackupDays, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" TextAlignment="Center"/>
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox Text="{Binding BackupPath, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" Margin="0,0,10,0"/>
                                <Button Grid.Column="1"
                                        Content="Обзор..."
                                        Command="{Binding SelectBackupPathCommand}"
                                        Style="{StaticResource ActionButtonStyle}"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="Создать копию сейчас"
                                        Command="{Binding CreateBackupCommand}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Восстановить из копии"
                                        Command="{Binding RestoreBackupCommand}"
                                        Style="{StaticResource ActionButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Безопасность -->
                    <Border Style="{StaticResource SettingsSectionStyle}">
                        <StackPanel>
                            <TextBlock Text="Безопасность" Style="{StaticResource SectionHeaderStyle}"/>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Требовать пароль при запуске" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding RequirePasswordOnStartup}" Style="{StaticResource GreenCheckBoxStyle}"/>
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Срок действия пароля (дней)" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="0 — никогда не истекает"
                                               FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Text="{Binding PasswordExpireDays, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" TextAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>

                            <Button Content="Изменить пароль"
                                    Command="{Binding ChangePasswordCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Интерфейс -->
                    <Border Style="{StaticResource SettingsSectionStyle}">
                        <StackPanel>
                            <TextBlock Text="Интерфейс" Style="{StaticResource SectionHeaderStyle}"/>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Язык интерфейса" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding SelectedLanguage}"/>
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Ширина окна по умолчанию" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding WindowWidth, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" TextAlignment="Center"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Высота окна по умолчанию" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding WindowHeight, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" TextAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Загрузка -->
        <Border Grid.RowSpan="2"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="3"
                             Foreground="{StaticResource AccentGreenBrush}"
                             Background="{StaticResource BorderLightBrush}"/>
                <TextBlock Text="Загрузка..."
                           Margin="0,10,0,0"
                           FontSize="13"
                           Foreground="{StaticResource MutedTextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
