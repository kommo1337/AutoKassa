<UserControl x:Class="AutoKassa.Views.CounterpartyEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Width="440" Margin="28">
        <StackPanel>
            <!-- TITLE -->
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"
                       Foreground="#1A1D23" Margin="0,0,0,24"/>

            <!-- NAME -->
            <TextBlock Text="НАЗВАНИЕ" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                    Margin="0,0,0,16">
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12" FontSize="14" Background="Transparent" BorderThickness="0"/>
            </Border>
            <TextBlock Text="{Binding NameError}" FontSize="12" Foreground="#ef4444"
                       Margin="0,-12,0,16"
                       Visibility="{Binding NameError, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- TYPE -->
            <TextBlock Text="ТИП" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                    Margin="0,0,0,16" Padding="4">
                <ComboBox ItemsSource="{Binding AvailableTypes}"
                          SelectedItem="{Binding Type}"
                          Padding="8" FontSize="14"
                          Background="Transparent" BorderThickness="0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource CounterpartyTypeToTextConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Border>

            <!-- PHONE -->
            <TextBlock Text="ТЕЛЕФОН" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                    Margin="0,0,0,16">
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12" FontSize="14" Background="Transparent" BorderThickness="0"/>
            </Border>

            <!-- NOTES -->
            <TextBlock Text="ПРИМЕЧАНИЯ" FontSize="11" FontWeight="SemiBold"
                       Foreground="#98A2B3" Margin="0,0,0,8"/>
            <Border Background="#F8F9FB" CornerRadius="11" BorderBrush="#E8EAED" BorderThickness="1"
                    Margin="0,0,0,24">
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12" FontSize="14" Background="Transparent" BorderThickness="0"
                         TextWrapping="Wrap" AcceptsReturn="False" Height="72" MaxLength="500"/>
            </Border>

            <!-- IS ACTIVE -->
            <CheckBox IsChecked="{Binding IsActive}" Content="Активен" FontSize="14"
                      Foreground="#344054" Margin="0,0,0,24"/>

            <!-- BUTTONS -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Отмена" Command="{Binding CancelCommand}"
                        Margin="0,0,8,0" Padding="12" FontSize="14" FontWeight="SemiBold"
                        Background="#F0F2F5" Foreground="#344054" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="11"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveCommand}"
                        Margin="8,0,0,0" Padding="12" FontSize="14" FontWeight="SemiBold"
                        Background="#22c55e" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="11"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
