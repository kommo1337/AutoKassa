<UserControl x:Class="AutoKassa.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             xmlns:views="clr-namespace:AutoKassa.Views"
             Background="#F0F2F5">

    <UserControl.Resources>
        <!-- Стиль чекбокса выделения строки -->
        <Style x:Key="SelectionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="bd" Width="18" Height="18" CornerRadius="5"
                                BorderBrush="#D0D5DD" BorderThickness="1.5" Background="White">
                            <TextBlock x:Name="chk" Text="✓" FontSize="10" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22c55e"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#22c55e"/>
                                <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#22c55e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding OpenInlineCommand}"/>
        <KeyBinding Key="F2" Command="{Binding EditCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="F5" Command="{Binding LoadCommand}"/>
    </UserControl.InputBindings>

    <!-- Root grid: content + FAB + modal overlay -->
    <Grid>

        <!-- ===== MAIN CONTENT (blurs when modal open) ===== -->
        <Grid x:Name="MainContent">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModalOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="6"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Grid Grid.Row="0" Margin="28,20,28,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Операции" FontSize="24" FontWeight="Bold"
                           Foreground="#1A1D23" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
                            CornerRadius="20" Padding="14,6" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↑" FontSize="11" Foreground="#22c55e"
                                       VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TotalIncomeFormatted}" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#15803d" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                            CornerRadius="20" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↓" FontSize="11" Foreground="#ef4444"
                                       VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TotalExpenseFormatted}" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#dc2626" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ===== CARD ===== -->
            <Border Grid.Row="1" Margin="28,0,28,0" CornerRadius="14" ClipToBounds="True"
                    BorderBrush="#E8EAED" BorderThickness="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ===== FILTER BAR (horizontal, single line) ===== -->
                    <Border Grid.Row="0" Padding="10,8,10,8"
                            BorderBrush="#F0F2F5" BorderThickness="0,0,0,1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- Search -->
                                <Border Background="#F8F9FB" BorderBrush="#E8EAED" BorderThickness="1"
                                        CornerRadius="9" Padding="8,5" Margin="0,0,6,0" MinWidth="200">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔍" FontSize="10" VerticalAlignment="Center"
                                                   Margin="0,0,5,0" Opacity="0.5"/>
                                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12" MinWidth="160"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalContentAlignment="Center" Foreground="#344054">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter" Command="{Binding ApplyFiltersCommand}"/>
                                            </TextBox.InputBindings>
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Grid>
                                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="Поиск..." Foreground="#98A2B3" FontSize="12"
                                                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>
                                </Border>

                                <!-- Period button + popup -->
                                <Grid Margin="0,0,6,0">
                                    <Button x:Name="PeriodBtn"
                                            Command="{Binding TogglePeriodPickerCommand}"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="#F8F9FB"
                                                        BorderBrush="#E8EAED" BorderThickness="1"
                                                        CornerRadius="9" Padding="8,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📅" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding PeriodLabel}" FontSize="12" Foreground="#344054" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" ▾" FontSize="10" Foreground="#98A2B3" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="MouseOver">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bd"
                                                                        Storyboard.TargetProperty="Background">
                                                                        <DiscreteObjectKeyFrame KeyTime="0">
                                                                            <DiscreteObjectKeyFrame.Value>
                                                                                <SolidColorBrush Color="#F0F2F5"/>
                                                                            </DiscreteObjectKeyFrame.Value>
                                                                        </DiscreteObjectKeyFrame>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Popup IsOpen="{Binding IsPeriodPickerOpen}"
                                           StaysOpen="False"
                                           PlacementTarget="{Binding ElementName=PeriodBtn}"
                                           Placement="Bottom"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade">
                                        <Border Background="White" BorderBrush="#E8EAED" BorderThickness="1"
                                                CornerRadius="14" Padding="16"
                                                MinWidth="310" Margin="0,6,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="24" ShadowDepth="8" Direction="270"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <!-- Раздел: быстрый выбор -->
                                                <TextBlock Text="БЫСТРЫЙ ВЫБОР" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="#98A2B3" Margin="0,0,0,10"/>
                                                <WrapPanel Margin="0,0,0,16">
                                                    <Button Content="Сегодня" Command="{Binding SelectPeriodCommand}" CommandParameter="Today"
                                                            Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                                    <Button Content="Эта неделя" Command="{Binding SelectPeriodCommand}" CommandParameter="Week"
                                                            Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                                    <Button Content="Этот месяц" Command="{Binding SelectPeriodCommand}" CommandParameter="Month"
                                                            Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                                    <Button Content="Прошлый месяц" Command="{Binding SelectPeriodCommand}" CommandParameter="LastMonth"
                                                            Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                                    <Button Content="Квартал" Command="{Binding SelectPeriodCommand}" CommandParameter="Quarter"
                                                            Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,6"/>
                                                </WrapPanel>

                                                <!-- Раздел: произвольный период -->
                                                <TextBlock Text="ПРОИЗВОЛЬНЫЙ ПЕРИОД" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="#98A2B3" Margin="0,0,0,10"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Дата от -->
                                                    <Grid>
                                                        <DatePicker x:Name="DateFromPicker"
                                                                    SelectedDate="{Binding DateFrom}"
                                                                    Width="118" FontSize="12"/>
                                                        <TextBlock Text="Дата от" Foreground="#C0C5D0"
                                                                   FontSize="12" VerticalAlignment="Center"
                                                                   Margin="9,0,0,0" IsHitTestVisible="False">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DateFrom}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>

                                                    <TextBlock Text="—" Foreground="#D0D5DD" FontSize="14"
                                                               VerticalAlignment="Center" Margin="8,0"/>

                                                    <!-- Дата до -->
                                                    <Grid>
                                                        <DatePicker x:Name="DateToPicker"
                                                                    SelectedDate="{Binding DateTo}"
                                                                    Width="118" FontSize="12"/>
                                                        <TextBlock Text="Дата до" Foreground="#C0C5D0"
                                                                   FontSize="12" VerticalAlignment="Center"
                                                                   Margin="9,0,0,0" IsHitTestVisible="False">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DateTo}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </StackPanel>

                                                <!-- Применить -->
                                                <Button Content="Применить" Command="{Binding ApplyFiltersCommand}"
                                                        Margin="0,12,0,0" Height="34" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btn" Background="#22c55e" CornerRadius="10">
                                                                <TextBlock Text="{TemplateBinding Content}"
                                                                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btn" Property="Background" Value="#16a34a"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Type chips: Все / Доходы / Расходы -->
                                <Border Background="#F8F9FB" BorderBrush="#E8EAED" BorderThickness="1"
                                        CornerRadius="9" Padding="3" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Все" Command="{Binding ResetTypeFilterCommand}" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAllTypeFilter}" Value="True">
                                                            <Setter Property="Background" Value="#1A1D23"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Доходы" Command="{Binding FilterByIncomeCommand}" Cursor="Hand" Margin="2,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsIncomeFilter}" Value="True">
                                                            <Setter Property="Background" Value="#22c55e"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Расходы" Command="{Binding FilterByExpenseCommand}" Cursor="Hand" Margin="2,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpenseFilter}" Value="True">
                                                            <Setter Property="Background" Value="#ef4444"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Wallet chips: Все / Нал / Безнал -->
                                <Border Background="#F8F9FB" BorderBrush="#E8EAED" BorderThickness="1"
                                        CornerRadius="9" Padding="3" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Все" Command="{Binding SelectAllPaymentCommand}" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAllPaymentFilter}" Value="True">
                                                            <Setter Property="Background" Value="#3b82f6"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Нал" Command="{Binding SelectCashFilterCommand}" Cursor="Hand" Margin="2,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCashFilter}" Value="True">
                                                            <Setter Property="Background" Value="#22c55e"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Безнал" Command="{Binding SelectNonCashFilterCommand}" Cursor="Hand" Margin="2,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNonCashFilter}" Value="True">
                                                            <Setter Property="Background" Value="#3b82f6"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Category custom dropdown -->
                                <Grid Margin="0,0,6,0">
                                    <Button x:Name="CategoryBtn"
                                            Command="{Binding ToggleCategoryPickerCommand}"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="#F8F9FB"
                                                        BorderBrush="#E8EAED" BorderThickness="1"
                                                        CornerRadius="9" Padding="8,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="{Binding SelectedCategory.Color, Converter={StaticResource CategoryColorConverter}}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="0">
                                                                            <Setter Property="Fill" Value="#1A1D23"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding SelectedCategory.Name, TargetNullValue='Категория'}"
                                                                   FontSize="12" Foreground="#344054" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" ▾" FontSize="10" Foreground="#98A2B3" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="MouseOver">
                                                                <Storyboard>
                                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bd"
                                                                        Storyboard.TargetProperty="Background">
                                                                        <DiscreteObjectKeyFrame KeyTime="0">
                                                                            <DiscreteObjectKeyFrame.Value>
                                                                                <SolidColorBrush Color="#F0F2F5"/>
                                                                            </DiscreteObjectKeyFrame.Value>
                                                                        </DiscreteObjectKeyFrame>
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Popup IsOpen="{Binding IsCategoryPickerOpen}"
                                           StaysOpen="False"
                                           PlacementTarget="{Binding ElementName=CategoryBtn}"
                                           Placement="Bottom"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade">
                                        <Border Background="White" BorderBrush="#E8EAED" BorderThickness="1"
                                                CornerRadius="12" Padding="8"
                                                MinWidth="210" Margin="0,4,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="24" ShadowDepth="8" Direction="270"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <!-- Search -->
                                                <Border Background="#F8F9FB" BorderBrush="#E8EAED" BorderThickness="1"
                                                        CornerRadius="8" Padding="8,5" Margin="0,0,0,4">
                                                    <TextBox Text="{Binding CategorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="12" Background="Transparent" BorderThickness="0"
                                                             VerticalContentAlignment="Center" Foreground="#344054">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="TextBox">
                                                                            <Grid>
                                                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                                                <TextBlock Text="Поиск категории..." Foreground="#98A2B3" FontSize="12"
                                                                                           VerticalAlignment="Center" IsHitTestVisible="False">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </Grid>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </Border>

                                                <!-- Category list -->
                                                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding FilteredCategories}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Cursor="Hand">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="itemBd" CornerRadius="8" Padding="8,6">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                                        <Style.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter Property="Background" Value="#F0F2F5"/>
                                                                                            </Trigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                                        <Ellipse.Style>
                                                                                            <Style TargetType="Ellipse">
                                                                                                <Setter Property="Fill" Value="{Binding Color, Converter={StaticResource CategoryColorConverter}}"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding Id}" Value="0">
                                                                                                        <Setter Property="Fill" Value="#1A1D23"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </Ellipse.Style>
                                                                                    </Ellipse>
                                                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                                                               Foreground="#344054" VerticalAlignment="Center"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Amount range: от / до -->
                                <Border Background="#F8F9FB" BorderBrush="#E8EAED" BorderThickness="1"
                                        CornerRadius="9" Padding="6,5" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox Text="{Binding AmountFromText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12" Width="55"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalContentAlignment="Center" Foreground="#344054">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter" Command="{Binding ApplyFiltersCommand}"/>
                                            </TextBox.InputBindings>
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Grid>
                                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="от ₽" Foreground="#98A2B3" FontSize="12"
                                                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <TextBlock Text="–" Foreground="#D0D5DD" FontSize="11"
                                                   VerticalAlignment="Center" Margin="3,0"/>
                                        <TextBox Text="{Binding AmountToText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="12" Width="55"
                                                 Background="Transparent" BorderThickness="0"
                                                 VerticalContentAlignment="Center" Foreground="#344054">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter" Command="{Binding ApplyFiltersCommand}"/>
                                            </TextBox.InputBindings>
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Grid>
                                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="до ₽" Foreground="#98A2B3" FontSize="12"
                                                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </StackPanel>
                                </Border>

                                <!-- Reset -->
                                <Button Command="{Binding ResetFiltersCommand}" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="#FEF2F2" CornerRadius="9"
                                                    BorderBrush="#FECACA" BorderThickness="1" Padding="10,5">
                                                <TextBlock Text="✕ Сбросить" FontSize="12" Foreground="#ef4444"/>
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal"/>
                                                        <VisualState x:Name="MouseOver">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bd"
                                                                    Storyboard.TargetProperty="Background">
                                                                    <DiscreteObjectKeyFrame KeyTime="0">
                                                                        <DiscreteObjectKeyFrame.Value>
                                                                            <SolidColorBrush Color="#FEE2E2"/>
                                                                        </DiscreteObjectKeyFrame.Value>
                                                                    </DiscreteObjectKeyFrame>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- ===== INLINE ADD ROW ===== -->
                    <Border Grid.Row="1"
                            Visibility="{Binding IsInlineOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="0,0,0,1"
                            Padding="14,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Type toggle ±-->
                            <Button Grid.Column="0" Command="{Binding InlineToggleTypeCommand}"
                                    Width="30" Height="30" Cursor="Hand" Margin="0,0,8,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#ef4444"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInlineIncome}" Value="True">
                                                            <Setter Property="Background" Value="#22c55e"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="−"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsInlineIncome}" Value="True">
                                                                <Setter Property="Text" Value="+"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Category ComboBox -->
                            <Border Grid.Column="1" Background="White" BorderBrush="#E8EAED" BorderThickness="1"
                                    CornerRadius="8" Margin="0,0,8,0">
                                <ComboBox ItemsSource="{Binding InlineCategories}"
                                          SelectedItem="{Binding InlineCategory}"
                                          FontSize="12" Background="Transparent"
                                          BorderThickness="0" MinHeight="0" Padding="6,4">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="12"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Border>

                            <!-- Amount TextBox -->
                            <Border Grid.Column="2" Background="White" BorderBrush="#E8EAED" BorderThickness="1"
                                    CornerRadius="8" Margin="0,0,8,0" Padding="8,5">
                                <TextBox Text="{Binding InlineAmountText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" FontFamily="Consolas"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalContentAlignment="Center" Foreground="#1A1D23">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding InlineSaveCommand}"/>
                                        <KeyBinding Key="Escape" Command="{Binding InlineCancelCommand}"/>
                                    </TextBox.InputBindings>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                            <TextBlock Text="0.00" Foreground="#98A2B3" FontSize="13"
                                                                       FontFamily="Consolas"
                                                                       VerticalAlignment="Center" IsHitTestVisible="False">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Border>

                            <!-- Cash / NonCash mini-toggle -->
                            <Border Grid.Column="3" Background="White" BorderBrush="#E8EAED" BorderThickness="1"
                                    CornerRadius="8" Padding="2" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding InlineSelectCashCommand}" Cursor="Hand"
                                            Height="24" MinWidth="36">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" CornerRadius="6" Padding="6,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding InlineIsCash}" Value="True">
                                                                    <Setter Property="Background" Value="#22c55e"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Нал"/>
                                                                <Setter Property="Foreground" Value="#667085"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding InlineIsCash}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Command="{Binding InlineSelectNonCashCommand}" Cursor="Hand"
                                            Height="24" MinWidth="44">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" CornerRadius="6" Padding="6,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding InlineIsNonCash}" Value="True">
                                                                    <Setter Property="Background" Value="#3b82f6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Безнал"/>
                                                                <Setter Property="Foreground" Value="#667085"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding InlineIsNonCash}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Save button ✓ -->
                            <Button Grid.Column="4" Command="{Binding InlineSaveCommand}"
                                    Width="30" Height="30" Cursor="Hand" Margin="0,0,4,0"
                                    ToolTip="Сохранить (Enter)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="#22c55e" CornerRadius="8">
                                            <TextBlock Text="✓" FontSize="14" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="MouseOver">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bg"
                                                                Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                                    <DiscreteObjectKeyFrame.Value>
                                                                        <SolidColorBrush Color="#16a34a"/>
                                                                    </DiscreteObjectKeyFrame.Value>
                                                                </DiscreteObjectKeyFrame>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Cancel button ✕ -->
                            <Button Grid.Column="5" Command="{Binding InlineCancelCommand}"
                                    Width="30" Height="30" Cursor="Hand" ToolTip="Отмена (Esc)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="#F0F2F5" CornerRadius="8">
                                            <TextBlock Text="✕" FontSize="13" Foreground="#667085"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="MouseOver">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bg"
                                                                Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                                    <DiscreteObjectKeyFrame.Value>
                                                                        <SolidColorBrush Color="#E2E5EA"/>
                                                                    </DiscreteObjectKeyFrame.Value>
                                                                </DiscreteObjectKeyFrame>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </Grid>
                    </Border>

                    <!-- ===== TRANSACTION LIST ===== -->
                    <Grid Grid.Row="2">

                        <!-- Empty state -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}"
                                    Margin="0,40">
                            <Border Width="52" Height="52" CornerRadius="14"
                                    Background="#F0F2F5" Margin="0,0,0,14" HorizontalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Операции не найдены" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#344054" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Попробуйте изменить фильтры" FontSize="13"
                                       Foreground="#98A2B3" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Grouped list -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding GroupedTransactions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- Day header -->
                                            <Border BorderBrush="#F0F2F5" BorderThickness="0,0,0,1"
                                                    Background="#F8F9FB">
                                                <Grid Margin="20,9,20,7">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DateLabel}" FontSize="12"
                                                               FontWeight="SemiBold" Foreground="#344054"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DayTotalFormatted}"
                                                               FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                                                               Foreground="{Binding DayTotalColor, Converter={StaticResource CategoryColorConverter}}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <!-- Transaction rows -->
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="RowBorder"
                                                                Padding="14,11,20,11"
                                                                BorderBrush="#F8F9FB" BorderThickness="0,0,0,1"
                                                                MouseLeftButtonDown="Row_MouseLeftButtonDown"
                                                                Cursor="Arrow">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#FAFAFA"/>
                                                                        </Trigger>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Border.ContextMenu>
                                                                <ContextMenu Opened="ContextMenu_Opened">
                                                                    <MenuItem Header="Редактировать (F2)" Click="EditMenuItem_Click"/>
                                                                    <Separator/>
                                                                    <MenuItem Header="Удалить" Click="DeleteMenuItem_Click" Foreground="#ef4444"/>
                                                                </ContextMenu>
                                                            </Border.ContextMenu>

                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="155"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="24"/>
                                                                    <ColumnDefinition Width="115"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Selection checkbox -->
                                                                <CheckBox Grid.Column="0"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                          Style="{StaticResource SelectionCheckBoxStyle}"
                                                                          Margin="0,0,10,0"/>

                                                                <!-- Category color dot -->
                                                                <Ellipse Grid.Column="1" Width="8" Height="8"
                                                                         Margin="0,0,11,0" VerticalAlignment="Center">
                                                                    <Ellipse.Fill>
                                                                        <MultiBinding Converter="{StaticResource TransactionDotColorConverter}">
                                                                            <Binding Path="Transaction.Type"/>
                                                                            <Binding Path="Transaction.Category.Color"/>
                                                                        </MultiBinding>
                                                                    </Ellipse.Fill>
                                                                </Ellipse>

                                                                <!-- Category name -->
                                                                <TextBlock Grid.Column="2" Text="{Binding Transaction.Category.Name}"
                                                                           FontSize="13" FontWeight="Medium" Foreground="#344054"
                                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                                                <!-- Description -->
                                                                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis" Margin="0,0,10,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding Transaction.Description, TargetNullValue='—'}"/>
                                                                            <Setter Property="FontSize" Value="12"/>
                                                                            <Setter Property="Foreground" Value="#667085"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Transaction.Description}" Value="">
                                                                                    <Setter Property="Text" Value="—"/>
                                                                                    <Setter Property="Foreground" Value="#D0D5DD"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>

                                                                <!-- Wallet icon -->
                                                                <TextBlock Grid.Column="4" FontSize="14"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Text="{Binding Transaction.PaymentType, Converter={StaticResource PaymentTypeToIconConverter}}"/>

                                                                <!-- Amount -->
                                                                <TextBlock Grid.Column="5" FontSize="13" FontWeight="SemiBold"
                                                                           FontFamily="Consolas" TextAlignment="Right"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{Binding Transaction.Type, Converter={StaticResource OperationTypeToColorConverter}}">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource TransactionAmountConverter}">
                                                                            <Binding Path="Transaction.Amount"/>
                                                                            <Binding Path="Transaction.Type"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Loading overlay -->
                        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                              Background="White" Opacity="0.75">
                            <ProgressBar IsIndeterminate="True" Width="180" Height="4"
                                         VerticalAlignment="Center" Background="Transparent"
                                         Foreground="#22c55e"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== FOOTER ===== -->
            <TextBlock Grid.Row="2"
                       Text="{Binding DisplayInfo}"
                       FontSize="11" Foreground="#98A2B3"
                       HorizontalAlignment="Center" Margin="0,6,0,10"/>
        </Grid>

        <!-- ===== FAB ===== -->
        <Button Command="{Binding AddCommand}"
                Width="52" Height="52"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,28,38"
                Cursor="Hand"
                ToolTip="Новая операция"
                Panel.ZIndex="50">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="fab" Background="#22c55e" CornerRadius="15">
                        <Border.Effect>
                            <DropShadowEffect Color="#22c55e" BlurRadius="18" ShadowDepth="4" Opacity="0.35"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="fab"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#16a34a" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <TextBlock Text="+" FontSize="28" Foreground="White" FontWeight="Light"
                       Margin="0,-2,0,0" VerticalAlignment="Center"/>
        </Button>

        <!-- ===== BULK SELECTION TOAST ===== -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,24" Panel.ZIndex="70"
                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#1A1D23" CornerRadius="28" Padding="16,10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.35" BlurRadius="24" ShadowDepth="6" Direction="270"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedCountLabel}" Foreground="White"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                               Margin="0,0,14,0"/>
                    <Rectangle Width="1" Height="18" Fill="#344054"/>
                    <!-- Delete button -->
                    <Button Command="{Binding DeleteSelectedCommand}" Cursor="Hand" Margin="14,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8" Padding="10,6" Background="#26EF4444">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Trash icon (SVG → WPF Path) -->
                                        <Viewbox Width="13" Height="13" Stretch="Uniform" Margin="0,0,6,0"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Path Stroke="#fca5a5" StrokeThickness="2"
                                                      StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Fill="Transparent"
                                                      Data="M3,6 L5,6 L21,6 M19,6 v14 a2,2 0 0,1 -2,2 H7 a2,2 0 0,1 -2,-2 V6 m3,0 V4 a2,2 0 0,1 2,-2 h4 a2,2 0 0,1 2,2 v2"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="Удалить" Foreground="#fca5a5" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#40EF4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Clear selection button -->
                    <Button Command="{Binding ClearSelectionCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="10" Padding="8,5" Background="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✕" Foreground="#98A2B3" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Снять" Foreground="#98A2B3" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#2d3748"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Border>

        <!-- ===== MODAL OVERLAY ===== -->
        <Grid Panel.ZIndex="100"
              Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- Backdrop -->
            <Rectangle Fill="#80000000"/>

            <!-- Modal card -->
            <Border Background="White" CornerRadius="16"
                    MaxWidth="470" MaxHeight="660"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="40" ShadowDepth="8" Direction="270"/>
                </Border.Effect>
                <views:TransactionEditView DataContext="{Binding EditViewModel}"/>
            </Border>

        </Grid>

    </Grid>
</UserControl>
