<UserControl x:Class="AutoKassa.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:OperationTypeToColorConverter x:Key="OperationTypeToColorConverter"/>
        <converters:OperationTypeToTextConverter x:Key="OperationTypeToTextConverter"/>

        <!-- Стиль для карточки категории -->
        <Style x:Key="CategoryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#2196F3" 
                                            Opacity="0.2" 
                                            BlurRadius="10" 
                                            ShadowDepth="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommand}"/>
        <KeyBinding Key="F2" Command="{Binding EditCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок и кнопки -->
            <RowDefinition Height="Auto"/>
            <!-- Фильтры -->
            <RowDefinition Height="*"/>
            <!-- Список категорий -->
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК И КНОПКИ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Категории" 
                       FontSize="24" 
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="➕ Добавить категорию"
                    Command="{Binding AddCommand}"
                    Background="{StaticResource SuccessBrush}"
                    Foreground="White"
                    Padding="20,12"
                    FontSize="14"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#43A047"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- ФИЛЬТРЫ -->
        <Border Grid.Row="1" 
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Показать:" 
                           FontSize="14" 
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>

                <!-- Кнопки фильтрации -->
                <ToggleButton Content="Все"
                              IsChecked="{Binding FilterType, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Null}"
                              Command="{Binding FilterCommand}"
                              CommandParameter="All"
                              Padding="15,8"
                              FontSize="14"
                              Margin="0,0,10,0">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <Button Content="Доходы"
                        Command="{Binding FilterCommand}"
                        CommandParameter="Income"
                        Padding="15,8"
                        FontSize="14"
                        Margin="0,0,10,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Расходы"
                        Command="{Binding FilterCommand}"
                        CommandParameter="Expense"
                        Padding="15,8"
                        FontSize="14">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- СПИСОК КАТЕГОРИЙ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- КАТЕГОРИИ ДОХОДОВ -->
                <StackPanel Visibility="{Binding ShowIncomeCategories, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Категории доходов" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,0,0,15"/>

                    <ItemsControl ItemsSource="{Binding IncomeCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CategoryCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Иконка и название -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Background="{Binding Type, Converter={StaticResource OperationTypeToColorConverter}}"
                                                    Width="40"
                                                    Height="40"
                                                    CornerRadius="20"
                                                    Margin="0,0,15,0">
                                                <TextBlock Text="💰" 
                                                          FontSize="20"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                          FontSize="16" 
                                                          FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <Border Background="{Binding Type, Converter={StaticResource OperationTypeToColorConverter}}"
                                                            CornerRadius="10"
                                                            Padding="8,3">
                                                        <TextBlock Text="{Binding Type, Converter={StaticResource OperationTypeToTextConverter}}"
                                                                  Foreground="White"
                                                                  FontSize="11"
                                                                  FontWeight="SemiBold"/>
                                                    </Border>

                                                    <!-- Статус активности -->
                                                    <Border Background="#757575"
                                                            CornerRadius="10"
                                                            Padding="8,3"
                                                            Margin="8,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="Неактивна"
                                                                  Foreground="White"
                                                                  FontSize="11"
                                                                  FontWeight="SemiBold"/>
                                                    </Border>

                                                    <!-- Системная категория -->
                                                    <Border Background="#FF9800"
                                                            CornerRadius="10"
                                                            Padding="8,3"
                                                            Margin="8,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="Системная"
                                                                  Foreground="White"
                                                                  FontSize="11"
                                                                  FontWeight="SemiBold"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Кнопки действий -->
                                        <StackPanel Grid.Column="2" 
                                                   Orientation="Horizontal"
                                                   VerticalAlignment="Center">
                                            <Button Content="✏️" 
        Click="EditButton_Click"
        Tag="{Binding}"
        ToolTip="Редактировать (F2)"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        FontSize="18"
        Width="36"
        Height="36"
        Margin="5,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="5">
                                                                        <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Content="🗑️" 
        Click="DeleteButton_Click"
        Tag="{Binding}"
        ToolTip="Удалить (Delete)"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        FontSize="18"
        Width="36"
        Height="36"
        Margin="5,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="5">
                                                                        <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- КАТЕГОРИИ РАСХОДОВ -->
                <StackPanel Margin="0,30,0,0"
                           Visibility="{Binding ShowExpenseCategories, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Категории расходов" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ErrorBrush}"
                               Margin="0,0,0,15"/>

                    <ItemsControl ItemsSource="{Binding ExpenseCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CategoryCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Иконка и название -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Background="{Binding Type, Converter={StaticResource OperationTypeToColorConverter}}"
                                                    Width="40"
                                                    Height="40"
                                                    CornerRadius="20"
                                                    Margin="0,0,15,0">
                                                <TextBlock Text="💸" 
                                                          FontSize="20"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                          FontSize="16" 
                                                          FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <Border Background="{Binding Type, Converter={StaticResource OperationTypeToColorConverter}}"
                                                            CornerRadius="10"
                                                            Padding="8,3">
                                                        <TextBlock Text="{Binding Type, Converter={StaticResource OperationTypeToTextConverter}}"
                                                                  Foreground="White"
                                                                  FontSize="11"
                                                                  FontWeight="SemiBold"/>
                                                    </Border>

                                                    <!-- Статус активности -->
                                                    <Border Background="#757575"
                                                            CornerRadius="10"
                                                            Padding="8,3"
                                                            Margin="8,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="Неактивна"
                                                                  Foreground="White"
                                                                  FontSize="11"
                                                                  FontWeight="SemiBold"/>
                                                    </Border>

                                                    <!-- Системная категория -->
                                                    <Border Background="#FF9800"
                                                            CornerRadius="10"
                                                            Padding="8,3"
                                                            Margin="8,0,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="Системная"
                                                               Foreground="White"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Кнопки действий -->
                                        <StackPanel Grid.Column="2" 
                                               Orientation="Horizontal"
                                               VerticalAlignment="Center">
                                            <Button Content="✏️" 
        Click="EditButton_Click"
        Tag="{Binding}"
        ToolTip="Редактировать (F2)"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        FontSize="18"
        Width="36"
        Height="36"
        Margin="5,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="5">
                                                                        <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Content="🗑️" 
        Click="DeleteButton_Click"
        Tag="{Binding}"
        ToolTip="Удалить (Delete)"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        FontSize="18"
        Width="36"
        Height="36"
        Margin="5,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="5">
                                                                        <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>