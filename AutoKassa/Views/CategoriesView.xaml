<UserControl x:Class="AutoKassa.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             xmlns:views="clr-namespace:AutoKassa.Views"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:OperationTypeToColorConverter x:Key="OperationTypeToColorConverter"/>
        <converters:OperationTypeToTextConverter x:Key="OperationTypeToTextConverter"/>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>

        <!-- Category card style -->
        <Style x:Key="CategoryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#2196F3" Opacity="0.2" BlurRadius="10" ShadowDepth="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding OpenManagerCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <!-- ===== MAIN CONTENT (blurs when modal open) ===== -->
        <Grid x:Name="MainContent" Margin="20">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModalOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="6"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Категории" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Command="{Binding OpenManagerCommand}"
                        Background="{StaticResource SuccessBrush}"
                        Foreground="White"
                        Padding="20,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M12.22 2h-.44a2 2 0 00-2 2v.18a2 2 0 01-1 1.73l-.43.25a2 2 0 01-2 0l-.15-.08a2 2 0 00-2.73.73l-.22.38a2 2 0 00.73 2.73l.15.1a2 2 0 011 1.72v.51a2 2 0 01-1 1.74l-.15.09a2 2 0 00-.73 2.73l.22.38a2 2 0 002.73.73l.15-.08a2 2 0 012 0l.43.25a2 2 0 011 1.73V20a2 2 0 002 2h.44a2 2 0 002-2v-.18a2 2 0 011-1.73l.43-.25a2 2 0 012 0l.15.08a2 2 0 002.73-.73l.22-.39a2 2 0 00-.73-2.73l-.15-.08a2 2 0 01-1-1.74v-.5a2 2 0 011-1.74l.15-.09a2 2 0 00.73-2.73l-.22-.38a2 2 0 00-2.73-.73l-.15.08a2 2 0 01-2 0l-.43-.25a2 2 0 01-1-1.73V4a2 2 0 00-2-2z"
                                                              Stroke="White" StrokeThickness="2" Fill="Transparent"
                                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                        <Path Data="M12 15a3 3 0 100-6 3 3 0 000 6z"
                                                              Stroke="White" StrokeThickness="2" Fill="Transparent"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="Управление категориями" Foreground="White"
                                                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#43A047"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- FILTERS -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Показать:" FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"/>

                    <Button Content="Все" Command="{Binding FilterCommand}" CommandParameter="All"
                            Padding="15,8" FontSize="14" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Доходы" Command="{Binding FilterCommand}" CommandParameter="Income"
                            Padding="15,8" FontSize="14" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Расходы" Command="{Binding FilterCommand}" CommandParameter="Expense"
                            Padding="15,8" FontSize="14">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFEBEE"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- CATEGORY LIST -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- INCOME -->
                    <StackPanel Visibility="{Binding ShowIncomeCategories, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Категории доходов" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,15"/>

                        <ItemsControl ItemsSource="{Binding IncomeCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CategoryCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Ellipse Width="40" Height="40" Margin="0,0,15,0"
                                                         Fill="{Binding Color, Converter={StaticResource CategoryColorConverter}}"/>

                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <Border Background="{Binding Type, Converter={StaticResource OperationTypeToColorConverter}}"
                                                                CornerRadius="10" Padding="8,3">
                                                            <TextBlock Text="{Binding Type, Converter={StaticResource OperationTypeToTextConverter}}"
                                                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </Border>

                                                        <Border Background="#757575" CornerRadius="10" Padding="8,3" Margin="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="Неактивна" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </Border>

                                                        <Border Background="#FF9800" CornerRadius="10" Padding="8,3" Margin="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="Системная" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- EXPENSE -->
                    <StackPanel Margin="0,30,0,0"
                                Visibility="{Binding ShowExpenseCategories, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Категории расходов" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,15"/>

                        <ItemsControl ItemsSource="{Binding ExpenseCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CategoryCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Ellipse Width="40" Height="40" Margin="0,0,15,0"
                                                         Fill="{Binding Color, Converter={StaticResource CategoryColorConverter}}"/>

                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <Border Background="{Binding Type, Converter={StaticResource OperationTypeToColorConverter}}"
                                                                CornerRadius="10" Padding="8,3">
                                                            <TextBlock Text="{Binding Type, Converter={StaticResource OperationTypeToTextConverter}}"
                                                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </Border>

                                                        <Border Background="#757575" CornerRadius="10" Padding="8,3" Margin="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="Неактивна" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </Border>

                                                        <Border Background="#FF9800" CornerRadius="10" Padding="8,3" Margin="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="Системная" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===== MODAL OVERLAY ===== -->
        <Grid Panel.ZIndex="100"
              Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- Backdrop -->
            <Rectangle Fill="#66000000"/>

            <!-- Modal card -->
            <Border Background="White" CornerRadius="20"
                    MaxWidth="520" MaxHeight="700"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="30" ShadowDepth="8"/>
                </Border.Effect>
                <views:CategoryManagerView DataContext="{Binding ManagerViewModel}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
