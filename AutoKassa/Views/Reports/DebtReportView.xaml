<UserControl x:Class="AutoKassa.Views.Reports.DebtReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:CounterpartyTypeToTextConverter x:Key="CounterpartyTypeToTextConverter"/>
        <converters:DebtStatusToTextConverter x:Key="DebtStatusToTextConverter"/>
        <converters:DebtStatusToColorConverter x:Key="DebtStatusToColorConverter"/>
        <converters:DecimalToStringConverter x:Key="DecimalToStringConverter"/>
        <converters:OperationTypeToTextConverter x:Key="OperationTypeToTextConverter"/>
        <converters:OperationTypeToColorConverter x:Key="OperationTypeToColorConverter"/>
        <converters:IsNegativeConverter x:Key="IsNegativeConverter"/>

        <!-- Стиль контекстного меню -->
        <Style x:Key="ModernContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.12" Direction="270"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="border" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8F9FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ФИЛЬТРЫ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20">
                <Grid>
                    <!-- Экспорт -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button Command="{Binding ExportToPdfCommand}" Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1" CornerRadius="8" Padding="12,6">
                                        <TextBlock Text="PDF" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ExportToExcelCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1" CornerRadius="8" Padding="12,6">
                                        <TextBlock Text="Excel" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <StackPanel>
                        <!-- Период -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Период:"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                        Width="130" Margin="0,0,8,0"/>
                            <TextBlock Text="—" VerticalAlignment="Center"
                                       Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}"/>
                            <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                        Width="130" Margin="0,0,16,0"/>
                            <Button Content="Сегодня" Command="{Binding SetPeriodCommand}" CommandParameter="Today" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPresetToday}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Неделя" Command="{Binding SetPeriodCommand}" CommandParameter="Week" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPresetWeek}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Месяц" Command="{Binding SetPeriodCommand}" CommandParameter="Month" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPresetMonth}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Квартал" Command="{Binding SetPeriodCommand}" CommandParameter="Quarter" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPresetQuarter}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Год" Command="{Binding SetPeriodCommand}" CommandParameter="Year">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPresetYear}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Направление -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Направление:"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                            <Button Content="Все" Command="{Binding SetDirectionAllCommand}" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirectionAll}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Нам должны" Command="{Binding SetDirectionIncomeCommand}" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirectionIncome}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Мы должны" Command="{Binding SetDirectionExpenseCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirectionExpense}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Статус -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Статус:"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                            <Button Content="Все" Command="{Binding SetStatusAllCommand}" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusAll}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Активные" Command="{Binding SetStatusActiveCommand}" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusActive}" Value="True">
                                                <Setter Property="Background" Value="#f59e0b"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#f59e0b"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Погашённые" Command="{Binding SetStatusRepaidCommand}" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusRepaid}" Value="True">
                                                <Setter Property="Background" Value="#3b82f6"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#3b82f6"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Списанные" Command="{Binding SetStatusWrittenOffCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusWrittenOff}" Value="True">
                                                <Setter Property="Background" Value="#6b7280"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#6b7280"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ИТОГИ -->
        <Grid Grid.Row="1" Margin="0,0,0,16"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Долгов" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding Report.Items.Count, StringFormat='N0'}"
                                   FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Rectangle Grid.Column="1" Fill="{StaticResource BorderLightBrush}"/>
                    <StackPanel Grid.Column="2" Margin="20,0">
                        <TextBlock Text="Нам должны" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding Report.ActiveReceivable, StringFormat='{}{0:N2} ₽'}"
                                   FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Rectangle Grid.Column="3" Fill="{StaticResource BorderLightBrush}"/>
                    <StackPanel Grid.Column="4" Margin="20,0">
                        <TextBlock Text="Мы должны" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding Report.ActivePayable, StringFormat='{}{0:N2} ₽'}"
                                   FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Rectangle Grid.Column="5" Fill="{StaticResource BorderLightBrush}"/>
                    <StackPanel Grid.Column="6" Margin="20,0">
                        <TextBlock Text="Баланс" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding Report.Balance, StringFormat='{}{0:N2} ₽'}"
                                   FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Report.Balance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Report.Balance}" Value="0">
                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- СПИСОК ДОЛГОВ (сгруппированный по дням) -->
        <Grid Grid.Row="2"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" ClipToBounds="True">
                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="True">
                    <ItemsControl ItemsSource="{Binding GroupedDebts}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  ScrollViewer.CanContentScroll="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>

                                    <!-- Заголовок дня -->
                                    <Border Background="#F8F9FB"
                                            BorderBrush="#F0F2F5"
                                            BorderThickness="0,0,0,1">
                                        <Grid Margin="20,9,20,8">
                                            <TextBlock Text="{Binding DateLabel}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#344054"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="Нам: " FontSize="11" Foreground="#667085"/>
                                                <TextBlock Text="{Binding DayReceivable, StringFormat='{}{0:N0} ₽'}"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,0,10,0"/>
                                                <TextBlock Text="Мы: " FontSize="11" Foreground="#667085"/>
                                                <TextBlock Text="{Binding DayPayable, StringFormat='{}{0:N0} ₽'}"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Строки долгов -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="20,11,20,11"
                                                        BorderBrush="#F8F9FB"
                                                        BorderThickness="0,0,0,1"
                                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Cursor="Hand">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#FAFAFA"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.ContextMenu>
                                                        <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                                            <MenuItem Header="Погасить"
                                                                      Tag="✅"
                                                                      Command="{Binding PlacementTarget.Tag.RepayDebtCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                                <MenuItem.Style>
                                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource MenuItemStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding PlacementTarget.DataContext.Status, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="Active">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </MenuItem.Style>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="115"/>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Точка направления -->
                                                        <Ellipse Grid.Column="0"
                                                                 Width="8" Height="8"
                                                                 Margin="0,0,11,0"
                                                                 VerticalAlignment="Center"
                                                                 Fill="{Binding Direction, Converter={StaticResource OperationTypeToColorConverter}}"/>

                                                        <!-- Контрагент -->
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding CounterpartyName}"
                                                                   FontSize="13" FontWeight="Medium"
                                                                   Foreground="#344054"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,12,0"/>

                                                        <!-- Тип контрагента -->
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CounterpartyType, Converter={StaticResource CounterpartyTypeToTextConverter}}"
                                                                   FontSize="12" Foreground="#667085"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,12,0"/>

                                                        <!-- Категория -->
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding CategoryName}"
                                                                   FontSize="12" Foreground="#667085"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,16,0"/>

                                                        <!-- Статус -->
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding Status, Converter={StaticResource DebtStatusToTextConverter}}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{Binding Status, Converter={StaticResource DebtStatusToColorConverter}}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,16,0"/>

                                                        <!-- Описание -->
                                                        <TextBlock Grid.Column="5"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   HorizontalAlignment="Left"
                                                                   Margin="0,0,16,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{Binding Description, TargetNullValue='—'}"/>
                                                                    <Setter Property="FontSize" Value="12"/>
                                                                    <Setter Property="Foreground" Value="#667085"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Description}" Value="">
                                                                            <Setter Property="Text" Value="—"/>
                                                                            <Setter Property="Foreground" Value="#D0D5DD"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <!-- Остаток -->
                                                        <TextBlock Grid.Column="6"
                                                                   Text="{Binding RemainingAmount, StringFormat='{}{0:N2} ₽'}"
                                                                   FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"
                                                                   TextAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Direction, Converter={StaticResource OperationTypeToColorConverter}}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ЗАГЛУШКА -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="40"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Нет данных"
                           FontSize="40"
                           Foreground="{StaticResource BorderLightBrush}"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Нет долгов за выбранный период"
                           FontSize="15"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- Загрузка -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Background="#80FFFFFF"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="..." FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="Формирование отчёта..."
                           FontSize="14" Margin="0,8,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
