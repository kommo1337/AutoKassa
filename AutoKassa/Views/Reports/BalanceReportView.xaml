<UserControl x:Class="AutoKassa.Views.Reports.BalanceReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ФИЛЬТРЫ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20">
                <Grid>
                <!-- Экспорт -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Command="{Binding ExportToPdfCommand}" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent"
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12,6">
                                    <TextBlock Text="PDF" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding ExportToExcelCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent"
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12,6">
                                    <TextBlock Text="Excel" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <!-- Период + кнопка -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Период:"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                    Width="130" Margin="0,0,8,0"/>

                        <TextBlock Text="—" VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>

                        <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                    Width="130"/>
                    </StackPanel>

                    <!-- Быстрые фильтры -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Сегодня" Click="QuickFilter_Click" Tag="Today" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetToday}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Неделя" Click="QuickFilter_Click" Tag="Week" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetWeek}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Месяц" Click="QuickFilter_Click" Tag="Month" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetMonth}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Квартал" Click="QuickFilter_Click" Tag="Quarter" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetQuarter}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Год" Click="QuickFilter_Click" Tag="Year">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetYear}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Фильтр типа оплаты -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Оплата:" FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Все" Command="{Binding SetPaymentAllCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentAll}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Наличные" Command="{Binding SetPaymentCashCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentCash}" Value="True">
                                            <Setter Property="Background" Value="#94a3b8"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#94a3b8"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Безналичные" Command="{Binding SetPaymentNonCashCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentNonCash}" Value="True">
                                            <Setter Property="Background" Value="#3b82f6"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#3b82f6"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
            </Border>
        </Grid>

        <!-- СВОДКА -->
        <Grid Grid.Row="1" Margin="0,0,0,16"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20,16">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Начальный баланс" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.StartBalance, Converter={StaticResource DecimalToStringConverter}}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="2" Margin="20,0">
                    <TextBlock Text="Доходы" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TotalIncome, Converter={StaticResource DecimalToStringConverter}}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="4" Margin="20,0">
                    <TextBlock Text="Расходы" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TotalExpense, Converter={StaticResource DecimalToStringConverter}}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="5" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="6" Margin="20,0">
                    <TextBlock Text="Конечный баланс" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.EndBalance, Converter={StaticResource DecimalToStringConverter}}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
            </Border>
        </Grid>

        <!-- ГРАФИК -->
        <Grid Grid.Row="2"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20">
                <Grid>
                <oxy:PlotView Model="{Binding PlotModel}" Background="Transparent"/>

                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                      Background="#AAFFFFFF">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="..." FontSize="48"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="Формирование отчёта..."
                                   FontSize="14"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
            </Border>
        </Grid>

        <!-- ЗАГЛУШКА -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="40"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Нет данных"
                           FontSize="40"
                           Foreground="{StaticResource BorderLightBrush}"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Нет операций за выбранный период"
                           FontSize="15"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
