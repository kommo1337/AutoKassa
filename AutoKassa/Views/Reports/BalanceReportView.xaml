<UserControl x:Class="AutoKassa.Views.Reports.BalanceReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:IsNegativeConverter x:Key="IsNegativeConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ФИЛЬТРЫ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20">
                <Grid>
                <!-- Экспорт -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Command="{Binding ExportToPdfCommand}" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent"
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12,6">
                                    <TextBlock Text="PDF" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding ExportToExcelCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent"
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12,6">
                                    <TextBlock Text="Excel" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <!-- Период + кнопка -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Период:"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                    Width="130" Margin="0,0,8,0"/>

                        <TextBlock Text="—" VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>

                        <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                    Width="130"/>
                    </StackPanel>

                    <!-- Быстрые фильтры -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Сегодня" Click="QuickFilter_Click" Tag="Today" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetToday}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Неделя" Click="QuickFilter_Click" Tag="Week" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetWeek}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Месяц" Click="QuickFilter_Click" Tag="Month" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetMonth}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Квартал" Click="QuickFilter_Click" Tag="Quarter" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetQuarter}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Год" Click="QuickFilter_Click" Tag="Year">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetYear}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Фильтр типа оплаты -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Оплата:" FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Все" Command="{Binding SetPaymentAllCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentAll}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Наличные" Command="{Binding SetPaymentCashCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentCash}" Value="True">
                                            <Setter Property="Background" Value="#94a3b8"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#94a3b8"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Безналичные" Command="{Binding SetPaymentNonCashCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentNonCash}" Value="True">
                                            <Setter Property="Background" Value="#3b82f6"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#3b82f6"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Кредит" Command="{Binding SetPaymentCreditCardCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentCreditCard}" Value="True">
                                            <Setter Property="Background" Value="#6366f1"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#6366f1"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
            </Border>
        </Grid>

        <!-- СВОДКА -->
        <Grid Grid.Row="1" Margin="0,0,0,16"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Карточки: Деньги + Кредит -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Деньги -->
                <Border Grid.Column="0" Background="#F0FFF4" CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="10" ShadowDepth="1" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Деньги" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Начальный баланс" FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       ToolTip="Остаток наличных и безналичных средств на начало периода"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Report.StartBalance, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Доходы" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                           ToolTip="Поступления наличных и безналичных денег за период"/>
                                <TextBlock Text=" +" FontSize="12" Foreground="{StaticResource AccentGreenBrush}" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Report.TotalIncome, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}"/>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Расходы" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                                           ToolTip="Расходы наличных и безналичных денег за период"/>
                                <TextBlock Text=" −" FontSize="12" Foreground="{StaticResource AccentRedBrush}" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Report.TotalExpense, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}"/>
                        </Grid>

                        <Border Grid.Row="3" VerticalAlignment="Bottom" Height="1" Background="#86efac" Margin="0,0,0,54"/>

                        <Grid Grid.Row="3" Margin="0,54,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Фактический баланс" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       ToolTip="Реальные деньги: начальный баланс + доходы − расходы (без кредитки)"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Report.FactBalance, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Кредит -->
                <Border Grid.Column="2" Background="#F5F3FF" CornerRadius="12" Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="10" ShadowDepth="1" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Кредит" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Кредитные покупки за период" FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       ToolTip="Сумма покупок по кредитным картам за выбранный период"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Report.TotalCreditPurchases, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="#6366f1"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Кредитный долг" FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       ToolTip="Общий текущий долг по всем кредитным картам"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Report.TotalCreditDebt, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}"/>
                        </Grid>

                        <Border Grid.Row="2" VerticalAlignment="Bottom" Height="1" Background="#c4b5fd" Margin="0,0,0,54"/>

                        <Grid Grid.Row="2" Margin="0,54,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Ближайший платёж" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           ToolTip="Сумма минимальных платежей по кредитным картам на ближайшую дату"/>
                                <TextBlock Text="{Binding Report.NextCreditPaymentDate, StringFormat={}{0:dd.MM.yyyy}}"
                                           FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Report.NextCreditPaymentAmount, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Чистый баланс -->
            <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="12" Padding="20,16" Margin="0,12,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="10" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Чистый баланс" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   ToolTip="Фактический баланс минус кредитный долг"/>
                        <TextBlock Text="{Binding Report.NetBalanceFormula}"
                                   FontSize="13" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding Report.NetBalance, Converter={StaticResource DecimalToStringConverter}}"
                               FontSize="26" FontWeight="Bold" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Report.NetBalance, Converter={StaticResource IsNegativeConverter}}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

        <!-- ГРАФИК -->
        <Grid Grid.Row="2"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20">
                <Grid>
                <oxy:PlotView x:Name="Plot" Model="{Binding PlotModel}" Background="Transparent"/>

                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                      Background="#AAFFFFFF">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="..." FontSize="48"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="Формирование отчёта..."
                                   FontSize="14"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
            </Border>
        </Grid>

        <!-- ЗАГЛУШКА -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="40"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Нет данных"
                           FontSize="40"
                           Foreground="{StaticResource BorderLightBrush}"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Нет операций за выбранный период"
                           FontSize="15"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
