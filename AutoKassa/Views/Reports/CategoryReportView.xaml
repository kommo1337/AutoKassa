<UserControl x:Class="AutoKassa.Views.Reports.CategoryReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ФИЛЬТРЫ -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Строка 1: период + тип + кнопка + экспорт -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Период:"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                    Width="130"
                                    Margin="0,0,8,0"/>

                        <TextBlock Text="—"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>

                        <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                    Width="130"
                                    Margin="0,0,16,0"/>

                        <!-- Переключатель тип: Расходы / Доходы -->
                        <Border Background="#F1F3F5" CornerRadius="8" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Margin="3">
                                <Button Content="Расходы" Command="{Binding ShowExpensesCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ReportTabButtonStyle}">
                                            <Setter Property="Padding" Value="12,6"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpenseSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Доходы" Command="{Binding ShowIncomeCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ReportTabButtonStyle}">
                                            <Setter Property="Padding" Value="12,6"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIncomeSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Button Content="Сформировать"
                                Command="{Binding GenerateCommand}"
                                Style="{StaticResource PillButton}"
                                Padding="20,8"/>
                    </StackPanel>

                    <!-- Экспорт -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding ExportToPdfCommand}"
                                Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,6">
                                        <TextBlock Text="PDF" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ExportToExcelCommand}"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,6">
                                        <TextBlock Text="Excel" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Строка 2: быстрые фильтры -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Content="Сегодня"  Click="QuickFilter_Click" Tag="Today"   Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="Неделя"   Click="QuickFilter_Click" Tag="Week"    Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="Месяц"    Click="QuickFilter_Click" Tag="Month"   Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="Квартал"  Click="QuickFilter_Click" Tag="Quarter" Style="{StaticResource PeriodPresetButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="Год"      Click="QuickFilter_Click" Tag="Year"    Style="{StaticResource PeriodPresetButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- СВОДКА -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="20,16"
                Margin="0,0,0,16"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Общая сумма" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TotalAmount, Converter={StaticResource DecimalToStringConverter}}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="2" Margin="20,0">
                    <TextBlock Text="Операций" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TransactionCount}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="4" Margin="20,0">
                    <TextBlock Text="Категорий" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.CategoryItems.Count}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ДИАГРАММА И ТАБЛИЦА -->
        <Grid Grid.Row="2"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- DONUT CHART -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBgBrush}"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,16,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Распределение"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Donut -->
                    <Grid Grid.Row="1" Width="260" Height="260"
                          HorizontalAlignment="Center" VerticalAlignment="Center">

                        <!-- Срезы -->
                        <ItemsControl ItemsSource="{Binding DonutSlices}">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ItemsPresenter/>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><Grid/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Path Data="{Binding Geometry}"
                                          Fill="{Binding Color, Converter={StaticResource CategoryColorConverter}}"
                                          Stroke="White"
                                          StrokeThickness="2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Текст в центре пончика -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    IsHitTestVisible="False">
                            <TextBlock Text="Итого"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Report.TotalAmount, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       MaxWidth="100"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Загрузка -->
                        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                              Background="#AAFFFFFF">
                            <TextBlock Text="..." FontSize="32"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ТАБЛИЦА КАТЕГОРИЙ -->
            <Border Grid.Column="1"
                    Background="{StaticResource CardBgBrush}"
                    CornerRadius="12"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Детализация по категориям"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Report.CategoryItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="4,10"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0"
                                                     Width="10" Height="10"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding Color}"/>
                                                </Ellipse.Fill>
                                            </Ellipse>

                                            <StackPanel Grid.Column="1" Margin="10,0">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource MutedTextBrush}">
                                                    <Run Text="{Binding Percentage, StringFormat={}{0:0.0}%}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding TransactionCount}"/>
                                                    <Run Text=" опер."/>
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Amount, Converter={StaticResource DecimalToStringConverter}}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ЗАГЛУШКА -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="40"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Нет данных"
                           FontSize="40"
                           Foreground="{StaticResource BorderLightBrush}"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Выберите период, тип операций и нажмите «Сформировать»"
                           FontSize="15"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
