<UserControl x:Class="AutoKassa.Views.Reports.CategoryReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AutoKassa.Views"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ФИЛЬТРЫ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Строка 1: период + тип + кнопка + экспорт -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Период:"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                    Width="130"
                                    Margin="0,0,8,0"/>

                        <TextBlock Text="—"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>

                        <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                    Width="130"
                                    Margin="0,0,16,0"/>

                        <!-- Переключатель тип: Расходы / Доходы -->
                        <Border Background="#F1F3F5" CornerRadius="8" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Margin="3">
                                <Button Content="Расходы" Command="{Binding ShowExpensesCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ReportTabButtonStyle}">
                                            <Setter Property="Padding" Value="12,6"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpenseSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Доходы" Command="{Binding ShowIncomeCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ReportTabButtonStyle}">
                                            <Setter Property="Padding" Value="12,6"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIncomeSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- Экспорт -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding ExportToPdfCommand}"
                                Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,6">
                                        <TextBlock Text="PDF" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ExportToExcelCommand}"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,6">
                                        <TextBlock Text="Excel" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Строка 2: быстрые фильтры + тип оплаты -->
                <StackPanel Grid.Row="1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Сегодня" Click="QuickFilter_Click" Tag="Today" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetToday}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Неделя" Click="QuickFilter_Click" Tag="Week" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetWeek}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Месяц" Click="QuickFilter_Click" Tag="Month" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetMonth}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Квартал" Click="QuickFilter_Click" Tag="Quarter" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetQuarter}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Год" Click="QuickFilter_Click" Tag="Year">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PeriodPresetButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetYear}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Фильтр типа оплаты -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Оплата:" FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Все" Command="{Binding SetPaymentAllCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentAll}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Наличные" Command="{Binding SetPaymentCashCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentCash}" Value="True">
                                            <Setter Property="Background" Value="#94a3b8"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#94a3b8"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Безналичные" Command="{Binding SetPaymentNonCashCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentNonCash}" Value="True">
                                            <Setter Property="Background" Value="#3b82f6"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#3b82f6"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
            </Border>
        </Grid>

        <!-- СВОДКА -->
        <Grid Grid.Row="1" Margin="0,0,0,16"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
            </Border>
            <Border Background="Transparent" CornerRadius="12" Padding="20,16">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Общая сумма" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TotalAmount, Converter={StaticResource DecimalToStringConverter}}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="2" Margin="20,0">
                    <TextBlock Text="Операций" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TransactionCount}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="4" Margin="20,0">
                    <TextBlock Text="Категорий" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.CategoryItems.Count}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
            </Border>
        </Grid>

        <!-- ДИАГРАММА И ТАБЛИЦА -->
        <Grid Grid.Row="2"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- DONUT CHART -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                    </Border.Effect>
                </Border>
                <Border Background="Transparent" CornerRadius="12" Padding="20">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Распределение"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Donut -->
                    <Grid Grid.Row="1" Width="260" Height="260"
                          HorizontalAlignment="Center" VerticalAlignment="Center">

                        <!-- Срезы -->
                        <ItemsControl ItemsSource="{Binding DonutSlices}">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ItemsPresenter/>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><Grid/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Path Data="{Binding Geometry}"
                                          Fill="{Binding Color, Converter={StaticResource CategoryColorConverter}}"
                                          Stroke="White"
                                          StrokeThickness="2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Текст в центре пончика -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    IsHitTestVisible="False">
                            <TextBlock Text="Итого"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Report.TotalAmount, Converter={StaticResource DecimalToStringConverter}}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       MaxWidth="100"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Загрузка -->
                        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                              Background="#AAFFFFFF">
                            <TextBlock Text="..." FontSize="32"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Grid>
                    </Grid>
                </Grid>
                </Border>
            </Grid>

            <!-- ТАБЛИЦА КАТЕГОРИЙ (раскрываемая) -->
            <Grid Grid.Column="1">
                <Border Background="{StaticResource CardBgBrush}" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                    </Border.Effect>
                </Border>
                <Border Background="Transparent" CornerRadius="12" Padding="20">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Детализация по категориям"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ExpandableItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <!-- Заголовок категории (клик = развернуть/свернуть) -->
                                        <Border Padding="4,10"
                                                BorderBrush="{StaticResource BorderLightBrush}"
                                                BorderThickness="0,0,0,1"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonDown="CategoryHeader_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Стрелка раскрытия -->
                                                <TextBlock Grid.Column="0"
                                                           FontSize="10"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="▶"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Text" Value="▼"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Ellipse Grid.Column="1"
                                                         Width="10" Height="10"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding Color, Converter={StaticResource CategoryColorConverter}}"/>

                                                <StackPanel Grid.Column="2" Margin="10,0">
                                                    <TextBlock Text="{Binding CategoryName}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource MutedTextBrush}">
                                                        <Run Text="{Binding Percentage, StringFormat={}{0:0.0}%, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding TransactionCount, Mode=OneWay}"/>
                                                        <Run Text=" опер."/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Amount, Converter={StaticResource DecimalToStringConverter}}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <!-- Список операций (раскрытый) -->
                                        <ItemsControl ItemsSource="{Binding Transactions}"
                                                      Margin="28,0,0,0">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="6,8"
                                                            BorderBrush="#F1F3F5"
                                                            BorderThickness="0,0,0,1"
                                                            Background="Transparent"
                                                            Cursor="Hand">
                                                        <Border.ContextMenu>
                                                            <ContextMenu Opened="TransactionContextMenu_Opened">
                                                                <ContextMenu.Style>
                                                                    <Style TargetType="ContextMenu">
                                                                        <Setter Property="Background" Value="White"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                        <Setter Property="Padding" Value="4"/>
                                                                        <Setter Property="HasDropShadow" Value="True"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="ContextMenu">
                                                                                    <Border Background="{TemplateBinding Background}"
                                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                                            CornerRadius="8"
                                                                                            Padding="{TemplateBinding Padding}">
                                                                                        <Border.Effect>
                                                                                            <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" ShadowDepth="2"/>
                                                                                        </Border.Effect>
                                                                                        <StackPanel IsItemsHost="True"/>
                                                                                    </Border>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </ContextMenu.Style>
                                                                <MenuItem Header="Редактировать"
                                                                          Click="EditMenuItem_Click">
                                                                    <MenuItem.Style>
                                                                        <Style TargetType="MenuItem">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                            <Setter Property="FontSize" Value="13"/>
                                                                            <Setter Property="Padding" Value="8,6"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="MenuItem">
                                                                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                                            <TextBlock Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="Bd" Property="Background" Value="#F1F3F5"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Style>
                                                                    </MenuItem.Style>
                                                                </MenuItem>
                                                                <MenuItem Header="Удалить"
                                                                          Click="DeleteMenuItem_Click">
                                                                    <MenuItem.Style>
                                                                        <Style TargetType="MenuItem">
                                                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                                            <Setter Property="FontSize" Value="13"/>
                                                                            <Setter Property="Padding" Value="8,6"/>
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                    <ControlTemplate TargetType="MenuItem">
                                                                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                                            <TextBlock Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="Bd" Property="Background" Value="#fef2f2"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Style>
                                                                    </MenuItem.Style>
                                                                </MenuItem>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock FontSize="12" Foreground="{StaticResource TextPrimaryBrush}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding Description}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Description}" Value="">
                                                                                    <Setter Property="Text" Value="Без описания"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                                                                    <Setter Property="Text" Value="Без описания"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                    <TextBlock Text="{Binding Date, StringFormat=d MMM yyyy}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource MutedTextBrush}"/>
                                                                    <TextBlock Text=" · "
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource MutedTextBrush}"/>
                                                                    <TextBlock FontSize="11"
                                                                               Foreground="{StaticResource MutedTextBrush}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="Наличные"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding PaymentType}" Value="NonCash">
                                                                                        <Setter Property="Text" Value="Безналичные"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Amount, Converter={StaticResource DecimalToStringConverter}}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ЗАГЛУШКА -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="40"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Нет данных"
                           FontSize="40"
                           Foreground="{StaticResource BorderLightBrush}"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Нет операций за выбранный период"
                           FontSize="15"
                           Foreground="{StaticResource MutedTextBrush}"
