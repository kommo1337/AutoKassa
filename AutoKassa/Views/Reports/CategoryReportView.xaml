<UserControl x:Class="AutoKassa.Views.Reports.CategoryReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <!-- Стиль для быстрых фильтров -->
        <Style x:Key="QuickFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               CornerRadius="4"
                               Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок переключения типа -->
        <Style x:Key="TypeToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               CornerRadius="4"
                               Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК И ПАРАМЕТРЫ -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <!-- Заголовок -->
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="Структура по категориям"
                               FontSize="24"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                               HorizontalAlignment="Right">
                        <Button Content="PDF"
                                Command="{Binding ExportToPdfCommand}"
                                Background="Transparent"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Padding="15,8"
                                Margin="0,0,10,0"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       CornerRadius="4"
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Excel"
                                Command="{Binding ExportToExcelCommand}"
                                Background="Transparent"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Padding="15,8"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       CornerRadius="4"
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Параметры -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Первая строка: период и кнопка -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Период:"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                   Width="140"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="—"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                   Width="140"
                                   Margin="0,0,20,0"/>

                        <!-- Переключатель типа операций -->
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Расходы"
                                        Command="{Binding ShowExpensesCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TypeToggleButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpenseSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Доходы"
                                        Command="{Binding ShowIncomeCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TypeToggleButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIncomeSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Button Content="Сформировать"
                               Command="{Binding GenerateCommand}"
                               Background="{StaticResource PrimaryBrush}"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="20,10"
                               Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                       CornerRadius="4"
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1976D2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Вторая строка: быстрые фильтры -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <Button Content="Сегодня" Click="QuickFilter_Click" Tag="Today" Style="{StaticResource QuickFilterButtonStyle}"/>
                        <Button Content="Неделя" Click="QuickFilter_Click" Tag="Week" Style="{StaticResource QuickFilterButtonStyle}"/>
                        <Button Content="Месяц" Click="QuickFilter_Click" Tag="Month" Style="{StaticResource QuickFilterButtonStyle}"/>
                        <Button Content="Квартал" Click="QuickFilter_Click" Tag="Quarter" Style="{StaticResource QuickFilterButtonStyle}"/>
                        <Button Content="Год" Click="QuickFilter_Click" Tag="Year" Style="{StaticResource QuickFilterButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- СВОДКА -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Общая сумма -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Общая сумма"
                              FontSize="12"
                              Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding Report.TotalAmount, Converter={StaticResource DecimalToStringConverter}}"
                              FontSize="24"
                              FontWeight="SemiBold"
                              Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Количество операций -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Количество операций"
                              FontSize="12"
                              Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding Report.TransactionCount}"
                              FontSize="24"
                              FontWeight="SemiBold"
                              Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Количество категорий -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Категорий"
                              FontSize="12"
                              Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding Report.CategoryItems.Count}"
                              FontSize="24"
                              FontWeight="SemiBold"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ГРАФИК И ТАБЛИЦА -->
        <Grid Grid.Row="2"
              Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Круговая диаграмма -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,20,0">
                <Grid>
                    <oxy:PlotView Model="{Binding PlotModel}"
                                  Background="Transparent"/>

                    <!-- Индикатор загрузки -->
                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="#88FFFFFF">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="..." FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Формирование отчета..."
                                       FontSize="16"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Таблица категорий -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="8"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Детализация по категориям"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Report.CategoryItems}"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Цветной индикатор -->
                                    <Ellipse Grid.Column="0"
                                             Width="12" Height="12"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Color}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!-- Название и процент -->
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   FontSize="14"
                                                   FontWeight="Medium"/>
                                        <TextBlock FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}">
                                            <Run Text="{Binding Percentage, StringFormat={}{0:0.0}%}"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding TransactionCount}"/>
                                            <Run Text=" опер."/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Сумма -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Amount, Converter={StaticResource DecimalToStringConverter}}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="#F0F0F0"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="5">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Заглушка если нет данных -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                Padding="40"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="O" FontSize="80" HorizontalAlignment="Center" FontFamily="Segoe UI Symbol"/>
                <TextBlock Text="Выберите период, тип операций и нажмите 'Сформировать'"
                          FontSize="18"
                          Foreground="{StaticResource SecondaryTextBrush}"
                          TextAlignment="Center"
                          Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
