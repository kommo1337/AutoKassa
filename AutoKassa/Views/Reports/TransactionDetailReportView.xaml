<UserControl x:Class="AutoKassa.Views.Reports.TransactionDetailReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>

        <!-- ComboBoxItem — скруглённый, hover зелёный -->
        <Style x:Key="ReportComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" CornerRadius="7" Padding="8,6" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bd" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"><DiscreteObjectKeyFrame.Value><SolidColorBrush Color="#F0FDF4"/></DiscreteObjectKeyFrame.Value></DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bd" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"><DiscreteObjectKeyFrame.Value><SolidColorBrush Color="#DCFCE7"/></DiscreteObjectKeyFrame.Value></DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="SelectedMouseOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bd" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0"><DiscreteObjectKeyFrame.Value><SolidColorBrush Color="#DCFCE7"/></DiscreteObjectKeyFrame.Value></DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox — кастомный, pill-border, popup с тенью -->
        <Style x:Key="ReportComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ReportComboBoxItemStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" Cursor="Hand"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="#F8F9FB" BorderBrush="#E8EAED"
                                                BorderThickness="1" CornerRadius="9" Padding="10,6">
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="MouseOver">
                                                        <Storyboard>
                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="bd" Storyboard.TargetProperty="Background">
                                                                <DiscreteObjectKeyFrame KeyTime="0"><DiscreteObjectKeyFrame.Value><SolidColorBrush Color="#F0F2F5"/></DiscreteObjectKeyFrame.Value></DiscreteObjectKeyFrame>
                                                            </ObjectAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Выбранный элемент -->
                            <Grid IsHitTestVisible="False" Margin="10,0,28,0">
                                <ContentPresenter x:Name="ContentSite"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            </Grid>

                            <!-- Стрелка -->
                            <TextBlock Text="▾" FontSize="10" Foreground="#98A2B3"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,10,0" IsHitTestVisible="False"/>

                            <!-- Dropdown -->
                            <Popup x:Name="Popup" Placement="Bottom" StaysOpen="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="White" BorderBrush="#E8EAED" BorderThickness="1"
                                        CornerRadius="10" Padding="4" Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="20" ShadowDepth="6" Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True" MaxHeight="220"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ФИЛЬТРЫ -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <Grid>
                <!-- Экспорт -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Command="{Binding ExportToPdfCommand}" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent"
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12,6">
                                    <TextBlock Text="PDF" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding ExportToExcelCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent"
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12,6">
                                    <TextBlock Text="Excel" FontSize="13" Foreground="{StaticResource MutedTextBrush}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <!-- Период -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Период:"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                    Width="130" Margin="0,0,8,0"/>
                        <TextBlock Text="—" VerticalAlignment="Center"
                                   Margin="0,0,8,0" Foreground="{StaticResource MutedTextBrush}"/>
                        <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                    Width="130" Margin="0,0,16,0"/>
                        <Button Content="Сегодня" Style="{StaticResource PeriodPresetButtonStyle}" Click="QuickFilterButton_Click" Tag="Today"   Margin="0,0,6,0"/>
                        <Button Content="Неделя"  Style="{StaticResource PeriodPresetButtonStyle}" Click="QuickFilterButton_Click" Tag="Week"    Margin="0,0,6,0"/>
                        <Button Content="Месяц"   Style="{StaticResource PeriodPresetButtonStyle}" Click="QuickFilterButton_Click" Tag="Month"   Margin="0,0,6,0"/>
                        <Button Content="Год"     Style="{StaticResource PeriodPresetButtonStyle}" Click="QuickFilterButton_Click" Tag="Year"/>
                    </StackPanel>

                    <!-- Тип + Категория + Кнопка -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Тип:"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <Button Content="Все" Command="{Binding ShowAllCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAllSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Расходы" Command="{Binding ShowExpensesCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpenseSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Доходы" Command="{Binding ShowIncomeCommand}" Margin="0,0,20,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsIncomeSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Text="Категория:"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <!-- Кастомный ComboBox -->
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                  Style="{StaticResource ReportComboBoxStyle}"
                                  Width="200"
                                  Margin="0,0,16,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Margin="0,0,7,0" VerticalAlignment="Center"
                                                 Fill="{Binding Color, Converter={StaticResource CategoryColorConverter}}"/>
                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                    </StackPanel>

                    <!-- Фильтр типа оплаты -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Оплата:" FontSize="13"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="Все" Command="{Binding SetPaymentAllCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentAll}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Наличные" Command="{Binding SetPaymentCashCommand}" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentCash}" Value="True">
                                            <Setter Property="Background" Value="#94a3b8"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#94a3b8"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Безналичные" Command="{Binding SetPaymentNonCashCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaymentNonCash}" Value="True">
                                            <Setter Property="Background" Value="#3b82f6"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#3b82f6"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ИТОГИ -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="20,16"
                Margin="0,0,0,16"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Операций" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TransactionCount, StringFormat='N0'}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Fill="{StaticResource BorderLightBrush}"/>
                <StackPanel Grid.Column="2" Margin="20,0">
                    <TextBlock Text="Доходы" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TotalIncome, StringFormat='{}{0:N2} ₽'}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Rectangle Grid.Column="3" Fill="{StaticResource BorderLightBrush}"/>
                <StackPanel Grid.Column="4" Margin="20,0">
                    <TextBlock Text="Расходы" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.TotalExpense, StringFormat='{}{0:N2} ₽'}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentRedBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Rectangle Grid.Column="5" Fill="{StaticResource BorderLightBrush}"/>
                <StackPanel Grid.Column="6" Margin="20,0">
                    <TextBlock Text="Разница" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding Report.NetAmount, StringFormat='{}{0:N2} ₽'}"
                               FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- СПИСОК ОПЕРАЦИЙ (сгруппированный по дням) -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GroupedTransactions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- Заголовок дня -->
                                <Border Background="#F8F9FB"
                                        BorderBrush="#F0F2F5"
                                        BorderThickness="0,0,0,1">
                                    <Grid Margin="20,9,20,8">
                                        <TextBlock Text="{Binding DateLabel}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#344054"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock HorizontalAlignment="Right"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding DayTotalFormatted}">
                                            <TextBlock.Foreground>
                                                <Binding Path="DayTotalColor" Converter="{StaticResource CategoryColorConverter}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- Строки операций -->
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="20,11,20,11"
                                                    BorderBrush="#F8F9FB"
                                                    BorderThickness="0,0,0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FAFAFA"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="155"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="115"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Цветная точка типа -->
                                                    <Ellipse Grid.Column="0"
                                                             Width="8" Height="8"
                                                             Margin="0,0,11,0"
                                                             VerticalAlignment="Center"
                                                             Fill="{Binding Type, Converter={StaticResource OperationTypeToColorConverter}}"/>

                                                    <!-- Категория -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding CategoryName}"
                                                               FontSize="13" FontWeight="Medium"
                                                               Foreground="#344054"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>

                                                    <!-- Описание -->
                                                    <TextBlock Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,10,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Description, TargetNullValue='—'}"/>
                                                                <Setter Property="FontSize" Value="12"/>
                                                                <Setter Property="Foreground" Value="#667085"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Description}" Value="">
                                                                        <Setter Property="Text" Value="—"/>
                                                                        <Setter Property="Foreground" Value="#D0D5DD"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Сумма -->
                                                    <TextBlock Grid.Column="3"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               FontFamily="Consolas"
                                                               TextAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding Type, Converter={StaticResource OperationTypeToColorConverter}}">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource TransactionAmountConverter}">
                                                                <Binding Path="Amount"/>
                                                                <Binding Path="Type"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ЗАГЛУШКА -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12"
                Padding="40"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Нет данных"
                           FontSize="40"
                           Foreground="{StaticResource BorderLightBrush}"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Нет операций за выбранный период"
                           FontSize="15"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- Загрузка -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Background="#80FFFFFF"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="..." FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="Формирование отчёта..."
                           FontSize="14" Margin="0,8,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
