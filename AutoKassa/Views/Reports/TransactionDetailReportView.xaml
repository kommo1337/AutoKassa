<UserControl x:Class="AutoKassa.Views.Reports.TransactionDetailReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <!-- Стиль для кнопок фильтра типа операций -->
        <Style x:Key="FilterToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               CornerRadius="4"
                               Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для активной кнопки фильтра -->
        <Style x:Key="ActiveFilterButtonStyle" TargetType="Button" BasedOn="{StaticResource FilterToggleButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК И ПАРАМЕТРЫ -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <!-- Заголовок -->
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="Детализация операций"
                               FontSize="24"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                               HorizontalAlignment="Right">
                        <Button Content="📊 PDF"
                                Command="{Binding ExportToPdfCommand}"
                                Background="Transparent"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Padding="15,8"
                                Margin="0,0,10,0"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       CornerRadius="4"
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="📑 Excel"
                                Command="{Binding ExportToExcelCommand}"
                                Background="Transparent"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Padding="15,8"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       BorderThickness="{TemplateBinding BorderThickness}"
                                                       CornerRadius="4"
                                                       Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Фильтры -->
                <StackPanel>
                    <!-- Период -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Период:"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay}"
                                   Width="140"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="—"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay}"
                                   Width="140"
                                   Margin="0,0,20,0"/>

                        <!-- Быстрые фильтры -->
                        <Button Content="Сегодня"
                                Style="{StaticResource FilterToggleButtonStyle}"
                                Click="QuickFilterButton_Click"
                                Tag="Today"/>
                        <Button Content="Неделя"
                                Style="{StaticResource FilterToggleButtonStyle}"
                                Click="QuickFilterButton_Click"
                                Tag="Week"/>
                        <Button Content="Месяц"
                                Style="{StaticResource FilterToggleButtonStyle}"
                                Click="QuickFilterButton_Click"
                                Tag="Month"/>
                        <Button Content="Год"
                                Style="{StaticResource FilterToggleButtonStyle}"
                                Click="QuickFilterButton_Click"
                                Tag="Year"/>
                    </StackPanel>

                    <!-- Тип операций и категория -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Тип:"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <Button Content="Все"
                                Command="{Binding ShowAllCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterToggleButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAllSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Расходы"
                                Command="{Binding ShowExpensesCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterToggleButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpenseSelected}" Value="True">
                                            <Setter Property="Background" Value="#F44336"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Доходы"
                                Command="{Binding ShowIncomeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource FilterToggleButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsIncomeSelected}" Value="True">
                                            <Setter Property="Background" Value="#4CAF50"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Text="Категория:"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="20,0,10,0"/>

                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Width="200"
                                  Margin="0,0,10,0"/>
                    </StackPanel>

                    <!-- Кнопка формирования -->
                    <Button Content="Сформировать отчет"
                            Command="{Binding GenerateCommand}"
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="20,10"
                            Cursor="Hand"
                            HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   BorderThickness="{TemplateBinding BorderThickness}"
                                                   CornerRadius="6"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ИТОГИ -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Количество операций -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Операций"
                               FontSize="13"
                               Foreground="#666666"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Report.TransactionCount, StringFormat='N0'}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Доходы -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Доходы"
                               FontSize="13"
                               Foreground="#666666"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Report.TotalIncome, StringFormat='{}{0:N2} ₽'}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#4CAF50"/>
                </StackPanel>

                <!-- Расходы -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Расходы"
                               FontSize="13"
                               Foreground="#666666"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Report.TotalExpense, StringFormat='{}{0:N2} ₽'}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#F44336"/>
                </StackPanel>

                <!-- Разница -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Разница"
                               FontSize="13"
                               Foreground="#666666"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Report.NetAmount, StringFormat='{}{0:N2} ₽'}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ТАБЛИЦА ОПЕРАЦИЙ -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
            <DataGrid ItemsSource="{Binding Report.Transactions}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F5F5F5"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- Дата -->
                    <DataGridTextColumn Header="Дата"
                                       Binding="{Binding Date, StringFormat='dd.MM.yyyy'}"
                                       Width="100"/>

                    <!-- Тип -->
                    <DataGridTextColumn Header="Тип"
                                       Binding="{Binding TypeName}"
                                       Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TypeName}" Value="Доход">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TypeName}" Value="Расход">
                                        <Setter Property="Foreground" Value="#F44336"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Сумма -->
                    <DataGridTextColumn Header="Сумма"
                                       Binding="{Binding Amount, StringFormat='{}{0:N2} ₽'}"
                                       Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Категория -->
                    <DataGridTextColumn Header="Категория"
                                       Binding="{Binding CategoryName}"
                                       Width="150"/>

                    <!-- Описание -->
                    <DataGridTextColumn Header="Описание"
                                       Binding="{Binding Description}"
                                       Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Индикатор загрузки -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Background="#80FFFFFF"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Формирование отчета..." FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
