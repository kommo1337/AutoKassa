<Window x:Class="AutoKassa.Views.ChangePasswordView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение пароля"
        Width="400"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="Изменение пароля"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <!-- Текущий пароль -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Текущий пароль" Margin="0,0,0,6" FontSize="13"/>
            <PasswordBox x:Name="CurrentPasswordBox"
                         PasswordChanged="CurrentPasswordBox_PasswordChanged"
                         Padding="12,10"
                         FontSize="14"/>
            <TextBlock Text="{Binding CurrentPasswordError}"
                       Foreground="{StaticResource ErrorBrush}"
                       FontSize="12"
                       Margin="0,4,0,0"
                       Visibility="{Binding CurrentPasswordError, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Новый пароль -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Новый пароль" Margin="0,0,0,6" FontSize="13"/>
            <PasswordBox x:Name="NewPasswordBox"
                         PasswordChanged="NewPasswordBox_PasswordChanged"
                         Padding="12,10"
                         FontSize="14"/>
            <TextBlock Text="{Binding NewPasswordError}"
                       Foreground="{StaticResource ErrorBrush}"
                       FontSize="12"
                       Margin="0,4,0,0"
                       Visibility="{Binding NewPasswordError, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Подтверждение пароля -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Подтвердите пароль" Margin="0,0,0,6" FontSize="13"/>
            <PasswordBox x:Name="ConfirmPasswordBox"
                         PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                         Padding="12,10"
                         FontSize="14"/>
            <TextBlock Text="{Binding ConfirmPasswordError}"
                       Foreground="{StaticResource ErrorBrush}"
                       FontSize="12"
                       Margin="0,4,0,0"
                       Visibility="{Binding ConfirmPasswordError, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Command="{Binding CancelCommand}"
                    Width="100"
                    Padding="0,12"
                    Margin="0,0,12,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    Width="100"
                    Padding="0,12"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
