<Window x:Class="AutoKassa.Views.LockScreenView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
        Title="Блокировка" 
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="#3F9C9B9B"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterOwner"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding UnlockCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelPasswordRecoveryCommand}"/>
    </Window.InputBindings>

    <Grid>
        <!-- Кнопка закрытия приложения -->
        <Button Content="✕"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="20"
            Width="40"
            Height="40"
            FontSize="20"
            Foreground="White"
            Background="#33FFFFFF"
            BorderThickness="0"
            Cursor="Hand"
            Click="CloseButton_Click"
            ToolTip="Закрыть приложение">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                   CornerRadius="20"
                                   BorderBrush="White"
                                   BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#55FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#77FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Основной экран блокировки -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPasswordRecoveryMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <StackPanel VerticalAlignment="Center" 
                   HorizontalAlignment="Center" 
                   Width="400">

                <!-- Карточка блокировки -->
                <Border Background="White"
                    CornerRadius="12"
                    Padding="40">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" 
                                    Direction="270" 
                                    ShadowDepth="5" 
                                    Opacity="0.3" 
                                    BlurRadius="20"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Логотип -->
                        <TextBlock Text="💼" 
                              FontSize="60" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,15"/>

                        <!-- Название -->
                        <TextBlock Text="АвтоКасса" 
                              FontSize="24" 
                              FontWeight="SemiBold"
                              Foreground="{StaticResource ForegroundBrush}"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,10"/>

                        <TextBlock Text="Приложение заблокировано" 
                              FontSize="13" 
                              Foreground="{StaticResource SecondaryTextBrush}"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,25"/>

                        <!-- Разделитель -->
                        <Border Height="1" 
                           Background="#E0E0E0"
                           Margin="0,0,0,25"/>

                        <!-- Поле пароля -->
                        <TextBlock Text="Пароль" 
                              FontSize="14" 
                              FontWeight="SemiBold"
                              Foreground="{StaticResource ForegroundBrush}"
                              Margin="0,0,0,8"/>

                        <Border Background="White" 
                           BorderBrush="#CCCCCC"
                           BorderThickness="1"
                           CornerRadius="4"
                           Padding="12"
                           x:Name="PasswordBorder">
                            <PasswordBox x:Name="PasswordBox"
                                    FontSize="16"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    PasswordChanged="PasswordBox_PasswordChanged"
                                    KeyDown="PasswordBox_KeyDown"/>
                        </Border>

                        <!-- Сообщение об ошибке -->
                        <TextBlock Text="{Binding ErrorMessage}" 
                              Foreground="{StaticResource ErrorBrush}"
                              FontSize="13"
                              TextWrapping="Wrap"
                              Margin="0,10,0,0"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Кнопка разблокировать -->
                        <Button Command="{Binding UnlockCommand}"
                           Content="Разблокировать"
                           Background="{StaticResource PrimaryBrush}"
                           Foreground="White"
                           Padding="0,14"
                           FontSize="15"
                           FontWeight="SemiBold"
                           BorderThickness="0"
                           Cursor="Hand"
                           Margin="0,20,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="4"
                                                   Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1976D2"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#CCCCCC"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Ссылка на восстановление пароля -->
                        <TextBlock Margin="0,15,0,0" 
                              HorizontalAlignment="Center">
                        <Hyperlink Command="{Binding ShowPasswordRecoveryCommand}"
                                  Foreground="{StaticResource PrimaryBrush}"
                                  TextDecorations="None">
                            <Run Text="Забыли пароль?"/>
                        </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Экран восстановления пароля -->
        <Grid Visibility="{Binding IsPasswordRecoveryMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" 
                   HorizontalAlignment="Center" 
                   Width="450">

                <Border Background="White"
                    CornerRadius="12"
                    Padding="40">
                    <Border.Effect>
                        <DropShadowEffect Color="#7F716767" 
                                    Direction="270" 
                                    ShadowDepth="5" 
                                    Opacity="0.3" 
                                    BlurRadius="20"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Восстановление пароля" 
                              FontSize="20" 
                              FontWeight="SemiBold"
                              Foreground="{StaticResource ForegroundBrush}"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,25"/>

                        <TextBlock Text="Функция восстановления будет реализована позже" 
                              FontSize="14"
                              Foreground="{StaticResource SecondaryTextBrush}"
                              TextWrapping="Wrap"
                              TextAlignment="Center"
                              Margin="0,0,0,25"/>

                        <Button Command="{Binding CancelPasswordRecoveryCommand}"
                           Content="Назад"
                           Background="Transparent"
                           Foreground="{StaticResource ForegroundBrush}"
                           BorderBrush="#CCCCCC"
                           BorderThickness="1"
                           Padding="20,12"
                           FontSize="14"
                           Cursor="Hand"
                           HorizontalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                   BorderBrush="{TemplateBinding BorderBrush}"
                                                   BorderThickness="{TemplateBinding BorderThickness}"
                                                   CornerRadius="4"
                                                   Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>