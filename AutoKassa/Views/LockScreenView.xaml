<Window x:Class="AutoKassa.Views.LockScreenView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AutoKassa.Helpers.Converters"
        Title="Блокировка - АвтоКасса" 
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#CC000000">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding UnlockCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelPasswordRecoveryCommand}"/>
    </Window.InputBindings>

    <Grid>
        <!-- Основной экран блокировки -->
        <Grid Visibility="{Binding IsPasswordRecoveryMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <Grid.Effect>
                <BlurEffect Radius="0" x:Name="BackgroundBlur"/>
            </Grid.Effect>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <!-- Логотип -->
                <TextBlock Text="💼" 
                           FontSize="80" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Название -->
                <TextBlock Text="АвтоКасса" 
                           FontSize="32" 
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Разделитель -->
                <Border Height="2" 
                        Background="White" 
                        Opacity="0.3"
                        Margin="0,20,0,30"/>

                <!-- Поле пароля -->
                <Border Background="White" 
                        CornerRadius="4"
                        Padding="15"
                        x:Name="PasswordBorder">
                    <PasswordBox x:Name="PasswordBox"
                                 FontSize="16"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 KeyDown="PasswordBox_KeyDown">
                        <PasswordBox.Resources>
                            <Style TargetType="PasswordBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="PasswordBox">
                                            <Grid>
                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                <TextBlock Text="Введите пароль" 
                                                          Foreground="#999999"
                                                          IsHitTestVisible="False"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding Path=Password, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </PasswordBox.Resources>
                    </PasswordBox>
                </Border>

                <!-- Сообщение об ошибке -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Кнопка разблокировать -->
                <Button Command="{Binding UnlockCommand}"
                        Content="Разблокировать"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        Padding="0,15"
                        FontSize="16"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,20,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Ссылка на восстановление пароля -->
                <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Hyperlink Command="{Binding ShowPasswordRecoveryCommand}"
                               Foreground="White"
                               TextDecorations="None">
                        <Run Text="Забыли пароль?"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Экран восстановления пароля -->
        <ContentControl Content="{Binding}" 
                        Visibility="{Binding IsPasswordRecoveryMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <!-- Здесь будет PasswordRecoveryView -->
                    <Border Background="#DD000000" Padding="40">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
                            <TextBlock Text="Восстановление пароля" 
                                       FontSize="24" 
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,30"/>

                            <TextBlock Text="Функция восстановления пароля будет реализована в следующем промпте" 
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>

                            <Button Command="{Binding CancelPasswordRecoveryCommand}"
                                    Content="Назад"
                                    Background="Transparent"
                                    Foreground="White"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    Padding="20,12"
                                    FontSize="14"
                                    Cursor="Hand"
                                    Margin="0,30,0,0"
                                    HorizontalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</Window>