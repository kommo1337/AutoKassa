<Window x:Class="AutoKassa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AutoKassa.ViewModels"
        xmlns:views="clr-namespace:AutoKassa.Views"

        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="768" Width="1366"
        MinHeight="720" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource ContentBgBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Кнопка тайтлбара (свернуть/развернуть) — для светлой зоны -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка закрытия -->
        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#e81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль навигационной кнопки сайдбара -->
        <Style x:Key="SidebarNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="64"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="6,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Горячие клавиши -->
    <Window.InputBindings>
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{Binding LockCommand}"/>
        <KeyBinding Key="D1" Modifiers="Alt" Command="{Binding NavigateToDashboardCommand}"/>
        <KeyBinding Key="D2" Modifiers="Alt" Command="{Binding NavigateToTransactionsCommand}"/>
        <KeyBinding Key="D3" Modifiers="Alt" Command="{Binding NavigateToReportsCommand}"/>
        <KeyBinding Key="D4" Modifiers="Alt" Command="{Binding NavigateToCreditCardsCommand}"/>
        <KeyBinding Key="D5" Modifiers="Alt" Command="{Binding NavigateToReconciliationCommand}"/>
        <KeyBinding Key="D6" Modifiers="Alt" Command="{Binding NavigateToSettingsCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- Кастомный TitleBar -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== TITLEBAR ==================== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Тёмная зона над сайдбаром -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"/>

            <!-- Светлая зона над контентом: название + кнопки -->
            <Border Grid.Column="1" Background="{StaticResource ContentBgBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Title}"
                               Margin="14,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Кнопки управления окном -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="MinimizeButton" Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButton}"
                            ToolTip="Свернуть">
                        <Path Data="M0,0 L10,0" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Click="MaximizeButton_Click"
                            Style="{StaticResource TitleBarButton}"
                            ToolTip="Развернуть">
                        <Grid>
                            <!-- Иконка "развернуть" (прямоугольник) -->
                            <Rectangle Width="10" Height="10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="1" Fill="Transparent">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <!-- Иконка "свернуть в окно" (два наложенных прямоугольника) -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Rectangle Width="8" Height="8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1" Fill="Transparent"
                                           HorizontalAlignment="Right" VerticalAlignment="Top"
                                           Margin="0,0,0,0"/>
                                <Rectangle Width="8" Height="8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1" Fill="{StaticResource ContentBgBrush}"
                                           HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                           Margin="0,0,2,0"/>
                            </Grid>
                        </Grid>
                    </Button>
                    <Button x:Name="CloseButton" Click="CloseButton_Click"
                            Style="{StaticResource TitleBarCloseButton}"
                            ToolTip="Закрыть">
                        <Path Data="M0,0 L10,10 M10,0 L0,10"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1"/>
                    </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="76"/>
            <!-- Тёмный сайдбар -->
            <ColumnDefinition Width="*"/>
            <!-- Контент -->
        </Grid.ColumnDefinitions>

        <!-- Toast-уведомления поверх всего -->
        <views:ToastOverlayView x:Name="ToastOverlay"
                                Grid.ColumnSpan="2"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,28"
                                Panel.ZIndex="300"/>

        <!-- ==================== САЙДБАР ==================== -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Логотип -->
                    <RowDefinition Height="*"/>
                    <!-- Навигация -->
                    <RowDefinition Height="Auto"/>
                    <!-- Замок -->
                </Grid.RowDefinitions>

                <!-- Логотип -->
                <Border Grid.Row="0" Height="56"
                        BorderBrush="#2a2d33" BorderThickness="0,0,0,1">
                    <TextBlock Text="AK"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,0,0,12"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>
                </Border>

                <!-- Навигационные кнопки -->
                <StackPanel Grid.Row="1" Margin="0,16,0,0">

                    <!-- Главная -->
                    <Button Command="{Binding NavigateToDashboardCommand}"
                            ToolTip="Главная (Alt+1)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22L9 12 15 12 15 22"
                                          StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Главная" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Операции -->
                    <Button Command="{Binding NavigateToTransactionsCommand}"
                            ToolTip="Операции (Alt+2)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTransactionsActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M8 6H21 M8 12H21 M8 18H21"
                                          StrokeThickness="2" Fill="Transparent"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <Ellipse Canvas.Left="3" Canvas.Top="4" Width="4" Height="4"
                                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <Ellipse Canvas.Left="3" Canvas.Top="10" Width="4" Height="4"
                                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <Ellipse Canvas.Left="3" Canvas.Top="16" Width="4" Height="4"
                                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Операции" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTransactionsActive}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Отчёты -->
                    <Button Command="{Binding NavigateToReportsCommand}"
                            ToolTip="Отчёты (Alt+3)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReportsActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M18 20V10 M12 20V4 M6 20V14"
                                          StrokeThickness="2" Fill="Transparent"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Отчёты" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReportsActive}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Кредитные карты -->
                    <Button Command="{Binding NavigateToCreditCardsCommand}"
                            ToolTip="Карты (Alt+4)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCreditCardsActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                                          StrokeThickness="2" Fill="Transparent"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Карты" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCreditCardsActive}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Сверка кассы -->
                    <Button Command="{Binding NavigateToReconciliationCommand}"
                            ToolTip="Сверка (Alt+5)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReconciliationActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
                                          StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Сверка" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReconciliationActive}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Настройки -->
                    <Button Command="{Binding NavigateToSettingsCommand}"
                            ToolTip="Настройки (Alt+6)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 15a3 3 0 100-6 3 3 0 000 6z M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"
                                          StrokeThickness="1.8" Fill="Transparent" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Настройки" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Кнопка блокировки внизу -->
                <Button Grid.Row="2"
                        Command="{Binding LockCommand}"
                        Style="{StaticResource SidebarNavButton}"
                        ToolTip="Заблокировать (Ctrl+L)"
                        Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="M7 11V7a5 5 0 0110 0v4"
                                      StrokeThickness="2" Fill="Transparent"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Path Data="M3 11h18v9a2 2 0 01-2 2H5a2 2 0 01-2-2V11z"
                                      StrokeThickness="2" Fill="Transparent"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Выход" FontSize="9" HorizontalAlignment="Center"
                                   Foreground="{StaticResource SidebarTextBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

        <!-- ==================== КОНТЕНТ ==================== -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <views:DashboardView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
                    <views:TransactionsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
                    <views:CategoriesView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                    <views:ReportsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:CreditCardsViewModel}">
                    <views:CreditCardsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:ReconciliationViewModel}">
                    <views:ReconciliationView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

        </Grid>
    </Grid>

</Window>
